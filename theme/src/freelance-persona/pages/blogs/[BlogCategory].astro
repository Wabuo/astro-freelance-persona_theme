---
import { getCollection } from "astro:content";
import BaseLayout from "@freelance-persona/layouts/BaseLayout.astro";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import Breadcrumbs from "@freelance-persona/components/ui/Breadcrumbs.astro";
import FilteredPostsSection from "@freelance-persona/components/sections/FilteredPostsSection.astro";
import Card from "@freelance-persona/components/ui/Card.astro";
import { Image } from "astro:assets";

// Generate paths for all categories defined in the section config
export async function getStaticPaths() {
  const sections = await getCollection("sections");
  // Find the blog_categories section
  // Note: There might be multiple if user defines multiples, but typically there's one main one.
  // We'll iterate all sections of type 'blog_categories' and flatten their categories.
  const blogSections = sections.filter(
    (s: any) => s.data.type === "blog_categories",
  );

  if (blogSections.length === 0) {
    return [];
  }

  // Helper to slugify - MUST MATCH the one in BlogCategoriesSection.astro
  const slugify = (text: string) =>
    text
      .toString()
      .toLowerCase()
      .trim()
      .replace(/\s+/g, "-")
      .replace(/[^\w-]+/g, "")
      .replace(/--+/g, "-");

  const paths: any[] = [];

  blogSections.forEach((section: any) => {
    if (section.data.type === "blog_categories") {
      // Process Main Categories
      if (section.data.categories) {
        section.data.categories.forEach((category: any) => {
          paths.push({
            params: { BlogCategory: slugify(category.title) },
            props: {
              title: category.title,
              description: category.description,
              tags: category.tags,
              parentId: section.data.custom_id || section.id,
              parentTitle: section.data.title,
              show_subtitle: category.show_subtitle,
              style: category.style,
            },
          });
        });
      }

      // Process Mini Categories
      if (section.data.mini_categories) {
        section.data.mini_categories.forEach((category: any) => {
          paths.push({
            params: { BlogCategory: slugify(category.title) },
            props: {
              title: category.title,
              description: category.description,
              tags: category.tags,
              parentId: section.data.custom_id || section.id,
              parentTitle: section.data.title,
              show_subtitle: category.show_subtitle,
              style: category.style,
            },
          });
        });
      }
    }
  });

  return paths;
}

const {
  title,
  description,
  tags,
  parentId,
  parentTitle,
  show_subtitle,
  style,
} = Astro.props;
const allPosts = await getCollection("blog_posts");

// Filter posts that match ANY of the category tags
const filteredPosts = allPosts
  .filter((post: any) =>
    post.data.tags.some((tag: string) => tags.includes(tag)),
  )
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
};
---

<BaseLayout title={`${title} - Blog`}>
  <Breadcrumbs
    crumbs={[
      { label: "Home", href: "/" },
      {
        label: parentTitle || "Blogs",
        href: `/#${parentId || "blog-categories"}`,
      },
      { label: title },
    ]}
    showTitle={false}
  />

  <div class="category-page-container section">
    <div class="section-header">
      <SectionTitle
        title={title}
        subtitle={show_subtitle ? description : undefined}
      />
    </div>

    {
      filteredPosts.length > 0 ? (
        style === "cards" ? (
          /* Cards Layout (Reused Section) */
          <FilteredPostsSection
            id="blog-category-posts"
            title=""
            posts={filteredPosts}
            limit={-1}
            columns={4}
            scale={0.9}
            tags_to_filter_posts_by={tags}
          />
        ) : (
          /* Simple Layout (List) - Existing Default */
          <div class="posts-list">
            {filteredPosts.map((post: any) => (
              <a href={`/posts/${post.id}`} class="post-entry-link">
                <article class="post-entry border-bottom">
                  <div class="post-meta d-flex justify-content-between align-items-center">
                    <h4 class="post-title">{post.data.title}</h4>
                    <div class="post-date">{formatDate(post.data.date)}</div>
                  </div>
                  <p class="post-description">{post.data.description}</p>
                </article>
              </a>
            ))}
          </div>
        )
      ) : (
        <div class="empty-state">
          <p>No posts found in this category yet.</p>
          <a href="/#blogs" class="btn-return">
            Return Home
          </a>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  /* Layout Refinements matching Zola Reference */
  .category-page-container {
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
  }

  /* Mimic Zola's airy layout */
  .posts-list {
    max-width: 80rem; /* 960px -> 60rem assuming 16px base */
    margin: 0 auto;
  }

  .post-entry-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-hover-time, 0.2s);
  }

  .post-entry {
    padding-bottom: 1.5rem; /* Match reference gap (24px) */
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color, rgba(0, 0, 0, 0.1));
    transition:
      border-color var(--transition-hover-time, 0.2s),
      transform 0.3s ease-out;
  }

  .post-entry-link:hover .post-entry {
    border-color: var(--accent-color);
    /* transform: translateX(5px); // Optional: slide effect */
  }

  /* Flexbox Layout for Title + Date */
  .post-meta {
    margin-bottom: var(--spacing-sm); /* 20px -> 16px */
    margin-top: var(--spacing-sm);
  }

  .post-title {
    margin: 0;
    font-size: var(--subtitle-font-size); /* 24px */
    font-family: var(--heading-font);
    font-weight: 500;
    color: var(--accent-color);
    transition: color var(--transition-hover-time, 0.2s);
  }

  .post-entry-link:hover .post-title {
    color: color-mix(
      in srgb,
      var(--accent-color),
      transparent var(--transition-hover-transparency, 20%)
    );
  }

  /* Increase specificity to override global .post-entry .post-meta .post-date */
  .post-entry .post-meta .post-date {
    font-size: var(--default-font-size);
    color: color-mix(in srgb, var(--default-color), transparent 50%);
    white-space: nowrap;
    margin-left: var(--spacing-sm);
    font-family: var(--default-font);
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .post-entry-link:hover .post-entry .post-meta .post-date {
    color: color-mix(in srgb, var(--accent-color), transparent 25%);
  }

  .post-description {
    text-align: justify;
    margin-bottom: 0; /* Remove browser default margin */
    line-height: 1.6;
    color: var(--default-color);
    transition: color var(--transition-hover-time, 0.2s);
  }

  .post-entry-link:hover .post-description {
    color: var(--accent-color);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-xxl) 0;
    opacity: 0.6;
    position: relative;
    min-height: 30vh; /* Create a separate visual pane */
    display: flex;
    flex-direction: column; /* Ensure p is at top */
    align-items: center;
  }

  .btn-return {
    position: absolute;
    bottom: -3rem;
    left: 0;
    right: 0;
    margin-inline: auto;
    width: fit-content;
    padding: 0.625rem 1.875rem;
    background-color: color-mix(in srgb, var(--accent-color), transparent 90%);
    color: var(--accent-color);
    text-decoration: none;
    border: none;
    border-radius: 3.125rem;
    transition:
      background-color var(--transition-hover-time, 0.3s),
      color var(--transition-hover-time, 0.3s),
      transform var(--transition-hover-time, 0.3s);
    font-weight: 600;
    /* Fix for Firefox font jitter: Force steady state rendering */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transform: translateZ(0);
    will-change: transform;
  }

  .btn-return:hover {
    background-color: var(--accent-color);
    color: var(--contrast-color, #fff);
    transform: translateY(-2px) translateZ(0);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .post-meta {
      flex-direction: column;
      align-items: flex-start !important;
    }
    .post-date {
      margin-left: 0;
      margin-top: var(--spacing-xs);
      font-size: 0.9rem;
    }
  }
</style>
