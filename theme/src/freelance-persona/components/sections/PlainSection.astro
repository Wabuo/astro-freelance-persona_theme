---
import SectionTitle from '@freelance-persona/components/ui/SectionTitle.astro';

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  nudge_x?: string;
  nudge_y?: string;
  content_scale?: number;
  delay?: number;
}
const { id, title, subtitle, nudge_x, nudge_y, content_scale, delay } = Astro.props;

// Visual Overrides CSS
const sectionStyle = `
  ${nudge_x ? `--nudge-x: ${nudge_x};` : ''}
  ${nudge_y ? `--nudge-y: ${nudge_y};` : ''}
  ${content_scale ? `--content-scale: ${content_scale};` : ''}
`;
---

<section id={id} class="plain section" style={sectionStyle}>
  <SectionTitle title={title} subtitle={subtitle} />
  
  <div class="container" data-reveal="fade-up" data-delay={delay || 100}>
    <div class="content">
      <slot /> </div>
  </div>
</section>

<style>
  .plain.section {
    transform: translate(var(--nudge-x, 0), var(--nudge-y, 0)) scale(var(--content-scale, 1));
  }
</style>
