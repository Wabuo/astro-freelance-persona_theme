---
// src/components/Navigation.astro
// Two-element navigation architecture: Desktop nav + Mobile popover nav
import { Icon } from "astro-icon/components";
import NavLinks from "@freelance-persona/components/ui/_NavLinks.astro";

// Props: isHome determines link behavior and styling
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
---

<!-- Desktop Navigation (always visible on desktop, hidden on mobile via CSS) -->
<header
  class={`header desktop-nav d-flex flex-column justify-content-center ${
    isHome ? "is-home" : "is-inner"
  }`}
>
  <NavLinks isHome={isHome} />
</header>

<!-- Mobile Navigation (popover drawer, hidden on desktop via CSS) -->
<header
  id="mobile-nav"
  popover="auto"
  class={`header mobile-nav flex-column ${isHome ? "is-home" : "is-inner"}`}
>
  <!-- Ghost Backdrop: Invisible to AT, handles click-to-close -->
  <button
    class="mobile-nav-backdrop"
    commandfor="mobile-nav"
    command="hide-popover"
    tabindex="-1"
  >
    <span class="sr-only">Close Menu</span>
  </button>

  <!-- Close Button: Fixed Position (Matches Nav Toggle) -->
  <button
    commandfor="mobile-nav"
    command="hide-popover"
    class="nav-close"
    aria-label="Close navigation menu"
  >
    <Icon name="bi:x" />
  </button>

  <!-- Visual Drawer: The actual menu content (Scroll Container) -->
  <div class="mobile-nav-drawer d-flex flex-column" id="mobile-nav-drawer">
    <NavLinks isHome={isHome} isMobile={true} />
  </div>
</header>

<!-- Mobile Toggle Button (visible only on mobile) -->
<button
  commandfor="mobile-nav"
  command="show-popover"
  class="nav-toggle"
  aria-label="Toggle navigation menu"
>
  <Icon name="bi:list" class="hamburger-icon" />
</button>

<style>
  /* Optional: Fix drawer height clipping for dropdowns near the bottom */
  :global(.mobile-nav-drawer) {
    padding-bottom: 2rem;
    overflow-y: auto;
  }

  /* Theme Toggle specific tweaks */
  :global(.theme-toggle) {
    background: none;
    border: none;
    color: var(--nav-color);
    width: 100%;
    display: flex;
    align-items: center;
    padding: 0.625rem 1.125rem;
    font-size: 0.9375rem;
    font-family: var(--nav-font);
    transition: 0.3s;
    border-radius: 3.125rem;
    margin-bottom: 0.5rem;
    gap: 0; /* Let native margins handle internal spacing */
  }

  :global(.theme-toggle-container) {
    /* Basic alignment */
    display: flex;
    flex-direction: column;
  }

  /* Make sure the icons container is sized correctly */
  :global(.theme-icon-container) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem; /* Match the 1.25rem footprint of standard navicons */
    height: 1.25rem;
    flex-shrink: 0;
  }

  :global(.toggle-dropdown) {
    font-size: 0.75rem; /* Match other dropdown chevrons */
    margin-left: 0.25rem; /* Pushed slightly right to avoid cutting off text */
    transition: 0.3s;
  }

  /* Hide textual label on desktop topnav */
  @media (min-width: 992px) {
    :global(.desktop-nav.is-inner .theme-toggle .theme-text-label),
    :global(.desktop-nav.is-inner .theme-toggle .toggle-dropdown) {
      display: none !important;
    }
    :global(.desktop-nav.is-inner .theme-toggle) {
      width: auto;
      padding: 1rem 0 1rem 1rem;
      margin-left: 0.5rem;
      border-left: 1px solid
        color-mix(in srgb, var(--default-color), transparent 85%);
      border-radius: 0;
      margin-bottom: 0;
    }
  }

  /* Dynamic Active state for the main toggle item */
  :global(.theme-toggle .navicon) {
    display: none;
  }
  :global(:root:has(.theme-state-os:checked) .theme-toggle .theme-icon-os),
  :global(
    :root:has(.theme-state-light:checked) .theme-toggle .theme-icon-light
  ),
  :global(:root:has(.theme-state-dark:checked) .theme-toggle .theme-icon-dark) {
    display: inline-block !important;
    width: 1em;
    height: 1em;
  }

  /* Styling for items in the dropdown drawer */
  :global(.theme-dropdown-menu) {
    min-width: 12.5rem !important; /* Force width matching inner page dropdowns */
  }

  :global(.theme-dropdown-menu .dropdown-item) {
    display: flex !important;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    width: 100%;
    color: var(
      --nav-dropdown-color
    ); /* Inherit default nav color on pure labels */
    min-width: 12.5rem; /* Ensure they match inner page sizes exactly */
    min-height: 2.5rem; /* Ensure they don't collapse to 0px height on mobile */
    padding: 0.5rem; /* Add some padding for the hover state */
    border-radius: 0.25rem;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
    position: relative; /* Anchor for the pseudo-element hitbox */
  }

  /* Native CSS Hitbox Fix: Stretch a transparent layer over the entire flex gap to capture clicks */
  :global(.theme-dropdown-menu .dropdown-item::before) {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1; /* Keep it above the background but below the text/icons if they need specific interactions */
  }

  /* Make sure the text takes remaining space to push toggles to the right */
  :global(.theme-dropdown-menu .theme-name) {
    flex-grow: 1;
    margin-right: auto;
    position: relative;
    z-index: 2; /* Keep labels above the clickable overlay just in case */
  }

  /* Dropdown Toggle Icons Base States */
  :global(.theme-dropdown-menu .toggle-icon) {
    margin-left: auto; /* Push it to the right */
  }

  :global(.theme-dropdown-menu .toggle-on),
  :global(.theme-dropdown-menu .toggle-off) {
    display: inline-block !important;
    padding-right: 1rem !important; /* Force explicit padding for toggle icons */
  }

  :global(.theme-dropdown-menu .toggle-on) {
    display: none !important;
  }

  /* Active states overrides */
  :global(
    :root:has(.theme-state-os:checked)
      .theme-dropdown-menu
      .theme-label-os
      .toggle-off
  ),
  :global(
    :root:has(.theme-state-light:checked)
      .theme-dropdown-menu
      .theme-label-light
      .toggle-off
  ),
  :global(
    :root:has(.theme-state-dark:checked)
      .theme-dropdown-menu
      .theme-label-dark
      .toggle-off
  ) {
    display: none !important;
  }

  :global(.theme-dropdown-menu .toggle-off) {
    display: inline-block !important;
  }

  :global(
    :root:has(.theme-state-os:checked)
      .theme-dropdown-menu
      .theme-label-os
      .toggle-on
  ),
  :global(
    :root:has(.theme-state-light:checked)
      .theme-dropdown-menu
      .theme-label-light
      .toggle-on
  ),
  :global(
    :root:has(.theme-state-dark:checked)
      .theme-dropdown-menu
      .theme-label-dark
      .toggle-on
  ) {
    display: inline-block !important;
  }

  /* Add active highlight to currently selected dropdown item natively */
  :global(
    :root:has(.theme-state-os:checked) .theme-dropdown-menu .theme-label-os
  ),
  :global(
    :root:has(.theme-state-light:checked)
      .theme-dropdown-menu
      .theme-label-light
  ),
  :global(
    :root:has(.theme-state-dark:checked) .theme-dropdown-menu .theme-label-dark
  ) {
    color: var(--nav-dropdown-hover-color);
  }

  /* Universal hover/focus state for dropdown items */
  :global(.theme-dropdown-menu .dropdown-item:hover),
  :global(.theme-dropdown-menu .dropdown-item:focus-within) {
    color: var(--nav-dropdown-hover-color) !important;
    background-color: color-mix(
      in srgb,
      var(--nav-dropdown-hover-color),
      transparent 92%
    );
  }
</style>

<script>
  // Navigation Interactions

  // 1. Mobile Navigation (Popover API)
  const initMobileNav = () => {
    const mobileNav = document.getElementById("mobile-nav");
    const drawer = document.getElementById("mobile-nav-drawer");
    const backdrop = document.querySelector(".mobile-nav-backdrop");

    // Close popover when a nav link is clicked (for same-page anchor navigation)
    document.querySelectorAll("#navmenu-mobile a").forEach((link) => {
      link.addEventListener("click", (e) => {
        // Exclude the Theme Toggle from closing the drawer
        if (link.id === "theme-toggle" || link.closest("#theme-toggle")) {
          return;
        }

        if (mobileNav && mobileNav.matches(":popover-open")) {
          mobileNav.hidePopover();
        }
      });
    });

    // SCROLL PROXY: Forward wheel events from backdrop to drawer
    // This allows user to scroll the menu even if their cursor is on the backdrop
    if (backdrop && drawer) {
      backdrop.addEventListener(
        "wheel",
        (e: Event) => {
          const wheelEvent = e as WheelEvent;
          // Prevent background scroll (redundant with overflow:hidden but good practice)
          e.preventDefault();
          // Scroll the drawer
          drawer.scrollBy({
            top: wheelEvent.deltaY,
            behavior: "auto", // 'smooth' feels laggy for wheel proxy
          });
        },
        { passive: false },
      );
    }
  };

  // 2. ScrollSpy (Highlight active link on scroll)
  const initScrollSpy = () => {
    const isHomePage = document.body.classList.contains("home-page");

    if (isHomePage) {
      // Target both desktop and mobile nav links
      const navLinks = document.querySelectorAll(
        "#navmenu a, #navmenu-mobile a",
      );
      const sections = document.querySelectorAll("section");

      const updateActiveLink = () => {
        let position = window.scrollY + 200;
        let currentActiveId: string | null = null;

        sections.forEach((section) => {
          if (position >= section.offsetTop) {
            const hasLink = Array.from(navLinks).some(
              (link) => link.getAttribute("href") === "#" + section.id,
            );
            if (hasLink) {
              currentActiveId = section.id;
            }
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("active");
          if (
            currentActiveId &&
            link.getAttribute("href") === "#" + currentActiveId
          ) {
            link.classList.add("active");
          }
        });

        // Edge case: Top of page (Hero)
        if (window.scrollY < 100) {
          navLinks.forEach((link) => link.classList.remove("active"));
          document
            .querySelectorAll(
              '#navmenu a[href="#hero"], #navmenu-mobile a[href="#hero"]',
            )
            .forEach((link) => {
              link.classList.add("active");
            });
        }
      };

      updateActiveLink();
      document.addEventListener("scroll", updateActiveLink);

      document.addEventListener(
        "astro:before-swap",
        () => {
          document.removeEventListener("scroll", updateActiveLink);
        },
        { once: true },
      );
    }
  };

  // 3. Theme Toggle Logic (Listening to UI Radio changes)
  const initThemeToggle = () => {
    // Hidden radios at top of DOM
    const radioInputs = document.querySelectorAll(
      ".theme-state-os, .theme-state-light, .theme-state-dark",
    );

    // Sync UI on load
    const syncState = () => {
      const storedTheme = localStorage.getItem("theme");
      if (storedTheme === "light" || storedTheme === "dark") {
        const el = document.getElementById(
          "theme-" + storedTheme,
        ) as HTMLInputElement;
        if (el) el.checked = true;
      } else {
        const el = document.getElementById("theme-os") as HTMLInputElement;
        if (el) el.checked = true;
      }
    };
    syncState();

    // Listen for UI label clicks which trigger radio 'change' events natively
    radioInputs.forEach((radio) => {
      radio.addEventListener("change", (e) => {
        const target = e.target as HTMLInputElement;
        if (!target.checked) return;

        const id = target.id;
        if (id === "theme-os") {
          localStorage.removeItem("theme");
        } else {
          const newTheme = id.replace("theme-", "");
          localStorage.setItem("theme", newTheme);
        }
      });
    });
  };

  // Centralized Initialization
  const initAll = () => {
    initMobileNav();
    initScrollSpy();
    initThemeToggle();
  };

  // Run on every page load (Client Router compatible)
  document.addEventListener("astro:page-load", initAll);
</script>
