---
// src/layouts/BaseLayout.astro
import Footer from '@freelance-persona/components/Footer.astro';
import Navigation from '@freelance-persona/components/Navigation.astro';
import { themeConfig } from '@freelance-persona/config'; 

// --- FONTS ---
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

import '@fontsource/raleway/300.css';
import '@fontsource/raleway/400.css';
import '@fontsource/raleway/500.css';
import '@fontsource/raleway/600.css';
import '@fontsource/raleway/700.css';

import '@fontsource/roboto/300.css';
import '@fontsource/roboto/300-italic.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/400-italic.css';
import '@fontsource/roboto/500.css';
import '@fontsource/roboto/500-italic.css';
import '@fontsource/roboto/700.css';
import '@fontsource/roboto/700-italic.css';

// Import Global Styles
import '@freelance-persona/styles/main.scss';

// --- SMART ASSET DISCOVERY ---
async function findAsset(glob: Record<string, () => Promise<any>>) {
  const paths = Object.keys(glob);
  if (paths.length === 0) return null;
  paths.sort((a, b) => {
    const score = (p: string) => p.endsWith('.svg') ? 4 : p.endsWith('.png') ? 3 : p.endsWith('.ico') ? 2 : 0;
    return score(b) - score(a);
  });
  const selectedPath = paths[0];
  const mod = await glob[selectedPath]();
  return mod.default;
}

const faviconSrc = await findAsset(
  import.meta.glob('/src/assets/img/favicon.{svg,ico,png,webp}', { query: { url: '' } })
);
const appleSrc = await findAsset(
  import.meta.glob('/src/assets/img/apple-touch-icon.{png,svg,webp}', { query: { url: '' } })
);

const getAssetUrl = (asset: any) => {
  if (!asset) return '';
  if (typeof asset === 'string') return asset;
  if (typeof asset === 'object' && asset.src) return asset.src;
  return '';
};

const getMime = (asset: any) => {
  if(!asset) return 'image/x-icon';
  if (typeof asset === 'object' && asset.format) {
     if (asset.format === 'svg') return 'image/svg+xml';
     if (asset.format === 'png') return 'image/png';
     if (asset.format === 'webp') return 'image/webp';
     return `image/${asset.format}`;
  }
  if (typeof asset === 'string') {
    if (/\.svg($|\?)/.test(asset)) return 'image/svg+xml';
    if (/\.png($|\?)/.test(asset)) return 'image/png';
    if (/\.ico($|\?)/.test(asset)) return 'image/x-icon';
    if (/\.webp($|\?)/.test(asset)) return 'image/webp';
  }
  return 'image/x-icon';
};

interface Props {
  title?: string;
  description?: string;
  tex?: boolean;
  navType?: 'home' | 'page'; 
}

const { 
  title = themeConfig.title, 
  description = themeConfig.description,
  tex = false,
  navType = 'page' 
} = Astro.props;

const bodyClass = navType === 'home' ? 'home-page' : 'inner-page';

// --- LAYOUT LOGIC ---
const layout = themeConfig.layout || {};
// Default left margin if not set. 140px matches standard sidebar width.
const globalMarginLeft = layout.margin_left || '140px';
// If margin_right is not explicitly set, force it to equal margin_left (Centering behavior)
const globalMarginRight = layout.margin_right || globalMarginLeft;
---

<!DOCTYPE html>
<html lang="en" style={`--global-margin-left: ${globalMarginLeft}; --global-margin-right: ${globalMarginRight};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={themeConfig.author} />

    {faviconSrc && (
      <link rel="icon" type={getMime(faviconSrc)} href={getAssetUrl(faviconSrc)} />
    )}
    {appleSrc && (
      <link rel="apple-touch-icon" href={getAssetUrl(appleSrc)} />
    )}
    
    <meta name="generator" content={Astro.generator} />
  </head>

  <body class={bodyClass} data-tex={tex}>
    <Navigation isHome={navType === 'home'} />

    <i class="nav-toggle d-lg-none bi bi-list"></i>

    <main class="main">
      <slot />
    </main>

    <Footer />

    <div id="preloader"></div>

    <script is:inline>
      function removePreloader() {
        const preloader = document.getElementById('preloader');
        if (preloader) {
          preloader.style.opacity = '0';
          setTimeout(() => { preloader.remove(); }, 600);
        }
      }
      window.addEventListener('load', removePreloader);
      setTimeout(removePreloader, 1500);
    </script>

    <script>
      import "../scripts/layout.js";
    </script>
  </body>
</html>