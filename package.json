{
  "name": "astro-freelance-persona-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.14.0",
    "bun": ">=1.1.0"
  },
  "workspaces": [
    "theme",
    "theme/starter"
  ],
  "scripts": {
    "dev": "cd playground && bun run dev",
    "build": "cd playground && bun run build",
    "preview": "cd playground && bun run preview",
    "check": "cd playground && bun run check",
    "test": "cd playground && bun run test",
    "test:e2e": "cd playground && bun run test",
    "test:e2e:ui": "cd playground && bun exec playwright test --ui",
    "playground:setup": "fuser -k 4321/tcp || true; fuser -k 4322/tcp || true; cd theme && bun link && cd .. && rm -rf playground && mkdir -p playground && cp -a theme/starter/. playground && cd playground && bun link astro-freelance-persona_theme"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.57.0"
  },
  "dependencies": {
    "@iconify-json/academicons": "^1.2.4",
    "@iconify-json/bi": "^1.2.7",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "katex": "^0.17.0"
  },
  "overrides": {
    "katex": "$katex"
  }
}