---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { themeConfig } from '@theme-config';

import Hero from '../Hero.astro';
import PlainSection from '../sections/PlainSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import CategorySection from '../sections/CategorySection.astro';

const heroSection = await getEntry('sections', 'hero') || {
  data: {
    title: "CONFIG MISSING",
    hero_typing_text: "Error: src/content/sections/hero.md not found", 
    greeting: "SYSTEM:",
    background_image: undefined
  }
};

// 3. Filter and Sort
const allSections = await getCollection('sections');
const contentSections = allSections
  .filter(s => s.id !== 'hero')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={themeConfig.title} navType="home">
  
  <Hero 
    title={heroSection.data.title} 
    hero_typing_text={heroSection.data.hero_typing_text} 
    greeting={heroSection.data.greeting}
    background_image={heroSection.data.background_image} 
  />

  {contentSections.map(async (section) => {
    const { Content } = await render(section);
    
    if (section.data.type === 'plain') {
      return (
        <PlainSection 
          slug={section.id} 
          title={section.data.title} 
          subtitle={section.data.subtitle}
        >
          <Content />
        </PlainSection>
      );
    }
    
    if (section.data.type === 'recent_posts') {
      return (
        <CategorySection 
          slug={section.id} 
          title={section.data.title} 
          subtitle={section.data.subtitle}
          blog_tag_filter={section.data.blog_tag_filter}
        />
      );
    }
    
    return null;
  })}

  <ContactSection />

</BaseLayout>