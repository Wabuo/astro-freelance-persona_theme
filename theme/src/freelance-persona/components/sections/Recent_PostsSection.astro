---
// src/components/sections/Recent_PostsSection.astro
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import Card from "@freelance-persona/components/ui/Card.astro";

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  tags_to_filter_posts_by?: string[];
}
const { id, title, subtitle, tags_to_filter_posts_by } = Astro.props;
console.log(
  `[Recent_PostsSection] id=${id} tags_type=${typeof tags_to_filter_posts_by} value=${JSON.stringify(tags_to_filter_posts_by)}`,
);

// 1. Fetch ALL posts
const allPosts = await getCollection("blog");

// 2. Filter Logic
// If a filter is provided, only keep posts that have at least one of the specified tags.
// If no filter is provided, keep everything.
const filteredPosts = tags_to_filter_posts_by
  ? allPosts.filter((post) =>
      post.data.tags?.some((tag) => tags_to_filter_posts_by.includes(tag)),
    )
  : allPosts;

// 3. Sort by Date & LIMIT to 3
// We only want the 3 newest posts for this specific section.
const displayedPosts = filteredPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

{/* Only render the section if we actually found posts for this category */}
{
  displayedPosts.length > 0 && (
    <section id={id} class="recent-posts section">
      <SectionTitle title={title} subtitle={subtitle} />

      <div class="container" data-reveal="fade-up">
        <div class="row gy-4" style="--bs-gutter-x: 1.7rem;">
          {displayedPosts.map((post) => (
            <div class="col-lg-4 col-md-6 mb-4">
              <Card href={`/blog/${post.id}`} class="h-100">
                {/* Image Slot: 16:9 Enforced */}
                <div slot="image" class="post-image-container">
                  {post.data.thumbnail ? (
                    <Image
                      src={post.data.thumbnail}
                      alt={post.data.title}
                      class="img-fluid post-image"
                      width={600}
                      quality="high"
                      format="webp"
                    />
                  ) : (
                    /* Preview Card: Mock Page Screenshot inside 16:9 container */
                    <div class="preview-card-wrapper h-100 w-100">
                      <div
                        class="mock-page-content"
                        style="width: 100%; height: 100%; padding: 1rem; background-color: var(--surface-color, #fff); color: var(--default-color);"
                      >
                        {/* Header Structure mimicking BlogPostTemplate - Natively Scaled (50%) */}
                        <div class="post-header">
                          <h2
                            class="post-title"
                            style="font-size: 1.25rem; margin-bottom: 0.25rem; color: var(--heading-color);"
                          >
                            {post.data.title}
                          </h2>

                          <div class="post-tags mb-0">
                            {post.data.tags?.map((tag) => (
                              <span
                                class="tag badge me-1"
                                style="background-color: color-mix(in srgb, var(--default-color), transparent 94%); color: color-mix(in srgb, var(--default-color), transparent 55%); padding: 0.2em 0.6em; border-radius: 0.1rem; font-size: 0.6em;"
                              >
                                {tag.toLowerCase()}
                              </span>
                            )) || <span class="tag badge me-1">blog</span>}
                          </div>

                          <hr style="margin: 0.75rem 0; opacity: 0.2; border-top: 1.5px solid;" />

                          <div
                            class="meta-top d-flex align-items-center small text-muted mb-2"
                            style="font-size: 0.6rem;"
                          >
                            <i class="bi bi-calendar-event me-1" />
                            {post.data.date.toLocaleDateString("en-GB", {
                              day: "2-digit",
                              month: "short",
                              year: "numeric",
                            })}
                            <span class="mx-2">|</span>
                            <i class="bi bi-hourglass-split me-1" />1 min read
                          </div>

                          <hr style="margin: 1.5rem 0; opacity: 0.2; border-top: 1.5px solid;" />

                          <div
                            class="post-content"
                            style="font-size: 0.625rem; line-height: 1.6;"
                          >
                            <p>{post.data.description}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                <div class="post-details">
                  <div class="meta mb-4">
                    {/* Tags Display */}
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="d-inline-block">
                        {post.data.tags.map((tag) => {
                          const isFiltered =
                            tags_to_filter_posts_by?.includes(tag);
                          return (
                            <span
                              class="badge me-1"
                              style={`
                                  font-size: 0.75em; 
                                  border-radius: 0.1875rem;
                                  padding: 0.2em 0.6em;
                                  font-weight: 500;
                                  display: inline-flex;
                                  align-items: center;
                                  justify-content: center;
                                  line-height: 1.5;
                                  ${
                                    isFiltered
                                      ? "background-color: color-mix(in srgb, var(--accent-color), transparent 92%); color: color-mix(in srgb, var(--accent-color), transparent 15%);"
                                      : "background-color: color-mix(in srgb, var(--default-color), transparent 94%); color: color-mix(in srgb, var(--default-color), transparent 55%);"
                                  }
                                `}
                            >
                              {tag}
                            </span>
                          );
                        })}
                      </div>
                    )}
                  </div>

                  <div class="post-content" style="flex-grow: 1;">
                    <h3 style="font-weight: 500; font-size: 1.25rem; margin-bottom: 0.5rem;">
                      {post.data.title}
                    </h3>
                    <p style="margin-left: 0;">
                      {post.data.description || "Click to read more..."}
                    </p>
                  </div>

                  {/* Date at Bottom Right */}
                  <span
                    class="date"
                    style={`
                        align-self: flex-end; 
                        margin-top: auto;
                        font-size: 0.75em; 
                        font-weight: 500;
                        line-height: 1.5;
                        color: color-mix(in srgb, var(--default-color), transparent 55%);
                      `}
                  >
                    {post.data.date.toLocaleDateString("en-GB", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                </div>
              </Card>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  /* Component styles moved to _recent-posts.scss */
</style>
