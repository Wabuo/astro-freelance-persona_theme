---
// src/components/sections/ContactSection.astro
import { themeConfig } from '@freelance-persona/config';
import SectionTitle from '@freelance-persona/components/ui/SectionTitle.astro';

const { contact_infos, web3form_public_key } = themeConfig;
const showForm = !!web3form_public_key;
---

<section id="contact" class="contact section">
  <SectionTitle title="Contact" />

  <div class="container" data-aos="fade" data-aos-delay="200">
    <div class="row gy-4">
      
      <div class={showForm ? "col-lg-4" : "col-lg-8 offset-lg-4"}>
        <div class="info-list d-flex flex-column gap-4" data-aos="fade-up" data-aos-delay="300">
          {contact_infos.map((info) => (
            <>
              {info.item === 'Email' ? (
                <a href={`mailto:${info.content}`} class="info-item d-flex email-wrapper">
                  <i class={info.icon_class}></i>
                  <div>
                    <h3>{info.item}</h3>
                    <p>{info.content}</p>
                  </div>
                </a>
              ) : (
                <div class="info-item d-flex">
                  <i class={info.icon_class}></i>
                  <div>
                    <h3>{info.item}</h3>
                    <p>{info.content}</p>
                  </div>
                </div>
              )}
            </>
          ))}
        </div>
      </div>

      {showForm && (
        <div class="col-lg-8">
          <form action="https://api.web3forms.com/submit" method="POST" class="contact-form" data-aos="fade-up" data-aos-delay="400">
            <input type="hidden" name="access_key" value={web3form_public_key} />
            
            <div class="row gy-4">
              <div class="col-md-6">
                <div class="input-box">
                    <input type="text" name="name" id="name-field" required />
                    <label for="name-field" class="label">Your Name</label>
                </div>
              </div>

              <div class="col-md-6">
                <div class="input-box">
                    <input type="email" name="email" id="email-field" required />
                    <label for="email-field" class="label">Your Email</label>
                </div>
              </div>

              <div class="col-md-12">
                <div class="input-box">
                    <input type="text" name="subject" id="subject-field" required />
                    <label for="subject-field" class="label">Subject</label>
                </div>
              </div>

              <div class="col-md-12">
                 <div class="input-box">
                    <textarea name="message" rows="6" id="message-field" required></textarea>
                    <label for="message-field" class="label">Message</label>
                </div>
              </div>

              <div class="col-md-12 text-center">
                <div class="loading">Loading</div>
                <div class="error-message"></div>
                <div class="sent-message">Your message has been sent. Thank you!</div>
                <button type="submit">Send Message</button>
              </div>
            </div>
          </form>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  /* 1. RESET: Make the anchor behave like a block div (no default link color) */
  .email-wrapper {
    text-decoration: none;
    color: inherit; /* Inherit text color from parent (usually dark/white) */
    cursor: pointer;
    transition: 0.3s;
  }
  
  /* 2. TEXT COLOR: The email address is ALWAYS accent color */
  .email-wrapper p {
    color: var(--accent-color);
    margin-bottom: 0;
    transition: 0.3s;
  }

  /* 3. HOVER STATE: Underline the text when hovering the wrapper */
  .email-wrapper:hover p {
    text-decoration: underline;
    text-decoration-color: var(--accent-color);
    text-underline-offset: 0.2rem; /* 3px -> ~0.2rem */
  }

  /* Optional: Light up the icon background on hover too (standard theme behavior) */
  .email-wrapper:hover i {
    background: var(--accent-color);
    color: var(--contrast-color);
  }
</style>