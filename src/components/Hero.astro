---
import { Image } from 'astro:assets';
import { themeConfig } from '../config';

interface Props {
  title: string;
  subtitles?: string;
  background_image?: ImageMetadata; 
}

const { title, subtitles, background_image: explicitImage } = Astro.props;
// --- DYNAMIC BACKGROUND LOGIC ---

let finalImage = explicitImage;

// If no image was defined in hero.md, search for a default 'background.*'
if (!finalImage) {
  // Added 'svg' to the list of extensions
  const bgGlob = import.meta.glob('/src/assets/img/background.{jpg,jpeg,png,webp,avif,svg}');
  const paths = Object.keys(bgGlob);
  
  if (paths.length > 0) {
    // Priority: JPG > PNG > WEBP > SVG > Others
    paths.sort((a, b) => {
      const score = (p: string) => 
        p.endsWith('.jpg') || p.endsWith('.jpeg') ? 4 : 
        p.endsWith('.png') ? 3 : 
        p.endsWith('.webp') ? 2 : 
        p.endsWith('.svg') ? 1 : 0;
      return score(b) - score(a);
    });
    // Load the file
    const imageModule = await bgGlob[paths[0]]();
    finalImage = imageModule.default;
  }
}
// --- END DYNAMIC LOGIC ---
---

<section id="hero" class="hero section">
  {finalImage && (
    <Image 
      src={finalImage} 
      alt="Background"
      class="hero-bg"
      width={1920} 
      height={1080}
      format="webp"
    />
  )}

  <div class="container" data-aos="zoom-out">
    <div class="row justify-content-center">
      <div class="col-lg-9">
        <h2>{title}</h2>
        {subtitles && (
          <p>I'm <span class="typed" data-typed-items={subtitles}></span><span class="typed-cursor typed-cursor--blink" aria-hidden="true"></span></p>
        )}
      </div>
    </div>
  </div>
</section>

<script>
  import Typed from 'typed.js';

  const typedElements = document.querySelectorAll('.typed');
  typedElements.forEach(element => {
    const strings = element.getAttribute('data-typed-items');
    if (strings) {
      new Typed(element, {
        strings: strings.split(','),
        loop: true,
        typeSpeed: 100,
        backSpeed: 50,
        backDelay: 2000
      });
    }
  });
</script>

<style>
  .hero-bg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
</style>