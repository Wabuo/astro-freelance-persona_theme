---
// src/freelance-persona/pages/blog/BlogPost.astro
import { getCollection, render } from "astro:content";
import BlogPostTemplate from "@freelance-persona/components/templates/BlogPostTemplate.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog_posts");
  return posts.map((post) => {
    // Flatten ID: remove subdirectory paths (e.g., 'archive/post' -> 'post')
    // This allows nested organization without changing URLs.
    const flatId = post.id.split("/").pop() || post.id;
    return {
      params: { id: flatId },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPostTemplate post={post}>
  <Content />
</BlogPostTemplate>
