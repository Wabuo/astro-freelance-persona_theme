---
import { getCollection } from "astro:content";
import BaseLayout from "@freelance-persona/layouts/BaseLayout.astro";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import Breadcrumbs from "@freelance-persona/components/ui/Breadcrumbs.astro";

// Generate paths for all categories defined in the section config
export async function getStaticPaths() {
  const sections = await getCollection("sections");
  // Find the blog_categories section
  // Note: There might be multiple if user defines multiples, but typically there's one main one.
  // We'll iterate all sections of type 'blog_categories' and flatten their categories.
  const blogSections = sections.filter(
    (s: any) => s.data.type === "blog_categories",
  );

  if (blogSections.length === 0) {
    return [];
  }

  // Helper to slugify - MUST MATCH the one in BlogCategoriesSection.astro
  const slugify = (text: string) =>
    text
      .toString()
      .toLowerCase()
      .trim()
      .replace(/\s+/g, "-")
      .replace(/[^\w-]+/g, "")
      .replace(/--+/g, "-");

  const paths: any[] = [];

  blogSections.forEach((section: any) => {
    if (section.data.type === "blog_categories" && section.data.categories) {
      section.data.categories.forEach((category: any) => {
        paths.push({
          params: { category: slugify(category.title) },
          props: {
            title: category.title,
            description: category.description,
            tags: category.tags,
            parentId: section.data.custom_id || section.id,
            parentTitle: section.data.title,
          },
        });
      });
    }
  });

  return paths;
}

const { title, description, tags, parentId, parentTitle } = Astro.props;
const allPosts = await getCollection("blog");

// Filter posts that match ANY of the category tags
const filteredPosts = allPosts
  .filter((post: any) =>
    post.data.tags.some((tag: string) => tags.includes(tag)),
  )
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
};
---

<BaseLayout title={`${title} - Blog`}>
  <Breadcrumbs
    crumbs={[
      { label: "Home", href: "/" },
      {
        label: parentTitle || "Blogs",
        href: `/#${parentId || "blog-categories"}`,
      },
      { label: title },
    ]}
    showTitle={false}
  />

  <div class="category-page-container section">
    <div class="section-header">
      <SectionTitle title={title} subtitle={description} />
    </div>

    {
      filteredPosts.length > 0 ? (
        <div class="posts-list">
          {filteredPosts.map((post: any) => (
            <article class="post-entry border-bottom">
              <div class="post-meta d-flex justify-content-between align-items-center">
                <h4 class="post-title">
                  <a href={`/blog/${post.id}`} class="post-link">
                    {post.data.title}
                  </a>
                </h4>
                <div class="post-date">{formatDate(post.data.date)}</div>
              </div>
              <p class="post-description">{post.data.description}</p>
              <a href={`/blog/${post.id}`} class="read-more-link">
                Read more &rarr;
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>No posts found in this category yet.</p>
          <a href="/" class="btn-return">
            Return Home
          </a>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  /* Layout Refinements matching Zola Reference */
  .category-page-container {
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
  }

  /* Mimic Zola's airy layout */
  .posts-list {
    max-width: 80rem; /* 960px -> 60rem assuming 16px base */
    margin: 0 auto;
  }

  .post-entry {
    padding-bottom: var(--spacing-lg); /* 30px -> 32px */
    margin-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color, rgba(0, 0, 0, 0.1));
  }

  /* Flexbox Layout for Title + Date */
  .post-meta {
    margin-bottom: var(--spacing-sm); /* 20px -> 16px */
    margin-top: var(--spacing-sm);
  }

  .post-title {
    margin: 0;
    font-size: var(--subtitle-font-size); /* 24px */
    font-family: var(--heading-font);
    font-weight: 500;
  }

  .post-link {
    text-decoration: none;
    color: var(
      --accent-color
    ); /* Zola reference shows titles in accent color */
    transition: color var(--transition-hover-time, 0.2s);
  }

  .post-link:hover {
    color: color-mix(
      in srgb,
      var(--accent-color),
      transparent var(--transition-hover-transparency, 20%)
    );
  }

  .post-date {
    font-size: var(--normal-font-size);
    /* Use color-mix for muted text if variable doesn't exist */
    color: color-mix(in srgb, var(--default-color), transparent 40%);
    white-space: nowrap;
    margin-left: var(--spacing-sm);
    font-family: var(--default-font);
  }

  .post-description {
    text-align: justify;
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
    color: var(--default-color);
  }

  .read-more-link {
    color: var(--accent-color);
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: transform var(--transition-hover-time, 0.2s);
  }

  .read-more-link:hover {
    transform: translateX(5px);
  }

  .empty-state {
    text-align: center;
    padding: var(--spacing-xxl) 0;
    opacity: 0.6;
  }

  .btn-return {
    display: inline-block;
    margin-top: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-sm);
    border: 1px solid var(--accent-color);
    color: var(--accent-color);
    text-decoration: none;
    border-radius: var(--spacing-xxs);
    transition: all var(--transition-hover-time, 0.3s);
  }

  .btn-return:hover {
    background: var(--accent-color);
    color: var(--contrast-color, #fff);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .post-meta {
      flex-direction: column;
      align-items: flex-start !important;
    }
    .post-date {
      margin-left: 0;
      margin-top: var(--spacing-xs);
      font-size: 0.9rem;
    }
  }
</style>
