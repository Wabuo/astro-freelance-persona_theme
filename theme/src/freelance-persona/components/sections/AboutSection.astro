---
import { Image } from "astro:assets";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import ImageAttribution from "@freelance-persona/components/ui/ImageAttribution.astro";
import { themeConfig } from "@freelance-persona/config";
import { Icon } from "astro-icon/components";
import { transformIcon } from "@freelance-persona/utils/iconUtils";

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  avatar?: ImageMetadata;
  avatar_credit?: { name: string; url: string; icon?: string } | "hidden";
  avatar_copyright?: string;
  avatar_license?: string | "hidden";
  qualifications_sidebar?: {
    text: string;
    subtitle?: string | string[];
    icon?: string;
    image?: ImageMetadata;
    img_credit?: { name: string; url: string; icon?: string } | "hidden";
    img_copyright?: string;
    img_license?: string | "hidden";
    link?: string;
  }[];

  nudge_x?: string;
  nudge_y?: string;
  content_scale?: number;
  delay?: number;

  avatar_styles?: {
    z_index?: number;
    float_margin_top?: string;
    float_margin_right?: string;
    float_margin_left?: string;
    float_margin_bottom?: string;
    grid_gap?: string;
    shape_outside_circle?: boolean;
  };
}
const {
  id,
  title,
  subtitle,
  avatar,
  avatar_credit,
  avatar_copyright,
  avatar_license,
  qualifications_sidebar,

  nudge_x,
  nudge_y,
  content_scale,
  delay,
  avatar_styles,
} = Astro.props;

// Visual Overrides CSS
const sectionStyle = `
  ${nudge_x ? `--nudge-x: ${nudge_x};` : ""}
  ${nudge_y ? `--nudge-y: ${nudge_y};` : ""}
  ${content_scale ? `--content-scale: ${content_scale};` : ""}
  --z-index: ${avatar_styles?.z_index || 10};
  --float-margin-top: ${avatar_styles?.float_margin_top || "0rem"};
  --float-margin-right: ${avatar_styles?.float_margin_right || "0rem"};
  --float-margin-left: ${avatar_styles?.float_margin_left || "2rem"};
  --float-margin-bottom: ${avatar_styles?.float_margin_bottom || "2rem"};
  --shape-outside: ${avatar_styles?.shape_outside_circle === false ? "none" : "circle(50%)"};
`;

const defaultContentDelay = themeConfig.visuals?.delays?.content || 200;

// Determine Layout Mode
const hasSidebar = !!(
  qualifications_sidebar && qualifications_sidebar.length > 0
);
---

<section id={id} class="about section" style={sectionStyle}>
  <SectionTitle title={title} subtitle={subtitle} />

  <div
    class={`container ${hasSidebar ? "container-grid" : ""}`}
    data-reveal="fade-up"
    data-reveal-delay={delay || defaultContentDelay}
  >
    <!-- Sidebar (Avatar + Profile Box) - Floated Right (Must be first in DOM for float) -->
    {
      hasSidebar && (
        <aside class="qualifications-sidebar">
          <div class="sidebar-content-wrapper">
            {avatar && (
              <div class="avatar-container">
                <Image
                  src={avatar}
                  alt="Profile Avatar"
                  class="avatar-image"
                  width={800}
                  height={800}
                />
                <ImageAttribution
                  img_credit={avatar_credit}
                  img_copyright={avatar_copyright}
                  img_license={avatar_license}
                />
              </div>
            )}

            {qualifications_sidebar && qualifications_sidebar.length > 0 && (
              <div class="qualifications-box">
                <ul class="qualifications-list">
                  {qualifications_sidebar.map((item) => {
                    const LinkTag = item.link ? "a" : "div";
                    const linkProps = item.link
                      ? {
                          href: item.link,
                          target: "_blank",
                          rel: "noopener noreferrer",
                        }
                      : {};

                    return (
                      <li class="qualifications-item">
                        {/* 1. Main Text/Icon Column */}
                        <LinkTag
                          {...linkProps}
                          class={
                            item.link
                              ? "qualifications-link"
                              : "qualifications-item-content"
                          }
                        >
                          {item.icon && (
                            <i
                              class={`${item.icon} qualifications-icon`}
                              aria-hidden="true"
                            />
                          )}

                          <div class="qualifications-text-col">
                            <span class="qualifications-text">{item.text}</span>
                            {item.subtitle &&
                              (Array.isArray(item.subtitle)
                                ? item.subtitle
                                : [item.subtitle]
                              ).map((sub) => (
                                <span class="qualifications-subtitle">
                                  {sub}
                                </span>
                              ))}
                          </div>
                        </LinkTag>

                        {/* 2. Image + Attribution Column (Sibling) */}
                        {item.image && (
                          <div style="display: flex; flex-direction: column; align-items: center; margin-left: 0.5rem;">
                            {/* Image Wrapper (Linked if item has link) */}
                            <LinkTag
                              {...linkProps}
                              class="cert-img-only-link"
                              aria-label={item.text}
                              style="display: block; line-height: 0;"
                            >
                              <div class="qualifications-cert-img">
                                <Image
                                  src={item.image}
                                  alt={item.text}
                                  width={50}
                                  height={50}
                                />
                              </div>
                            </LinkTag>

                            {/* Attribution (Outside Link) */}
                            <ImageAttribution
                              img_credit={item.img_credit}
                              img_copyright={item.img_copyright}
                              img_license={item.img_license}
                              containerClass="cert-attribution"
                              disableLinks={false}
                            />
                          </div>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </div>
            )}
          </div>
        </aside>
      )
    }

    <!-- Main Content (Text) - Flows around the float -->
    <div class="content main-content">
      {/* Floating Avatar (Fallback for no sidebar) */}
      {
        avatar && !hasSidebar && (
          <div class="avatar-float">
            <Image
              src={avatar}
              alt="Profile Avatar"
              class="avatar-image"
              width={800}
              height={800}
            />
          </div>
        )
      }
      <slot />
    </div>
  </div>
</section>
