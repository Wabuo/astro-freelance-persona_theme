---
interface Props {
  title: string;
  subtitle?: string;
  delay?: number;
}
const { title, subtitle, delay } = Astro.props;
---

<div class="section-title" data-reveal="fade-up" data-delay={delay}>
  <h2>
    {title}
    {
      subtitle && (
        <em>
          <br />
          {subtitle}
        </em>
      )
    }
  </h2>
</div>
