---
// src/freelance-persona/layouts/BaseLayout.astro
import { ClientRouter } from 'astro:transitions';
import Footer from '@freelance-persona/components/Footer.astro';
import Navigation from '@freelance-persona/components/Navigation.astro';
import { themeConfig } from '@freelance-persona/config'; 

// Font imports removed - should be handled by the consumer/starter


// Import Global Styles
import '@freelance-persona/styles/main.scss';

// --- SMART ASSET DISCOVERY ---
async function findAsset(glob: Record<string, () => Promise<any>>) {
  const paths = Object.keys(glob);
  if (paths.length === 0) return null;
  paths.sort((a, b) => {
    const score = (p: string) => p.endsWith('.svg') ? 4 : p.endsWith('.png') ? 3 : p.endsWith('.ico') ? 2 : 0;
    return score(b) - score(a);
  });
  const selectedPath = paths[0];
  const mod = await glob[selectedPath]();
  return mod.default;
}

const faviconSrc = await findAsset(
  import.meta.glob('/src/assets/img/favicon.{svg,ico,png,webp}', { query: { url: '' } })
);
const appleSrc = await findAsset(
  import.meta.glob('/src/assets/img/apple-touch-icon.{png,svg,webp}', { query: { url: '' } })
);

const getAssetUrl = (asset: any) => {
  if (!asset) return '';
  if (typeof asset === 'string') return asset;
  if (typeof asset === 'object' && asset.src) return asset.src;
  return '';
};

const getMime = (asset: any) => {
  if(!asset) return 'image/x-icon';
  if (typeof asset === 'object' && asset.format) {
     if (asset.format === 'svg') return 'image/svg+xml';
     if (asset.format === 'png') return 'image/png';
     if (asset.format === 'webp') return 'image/webp';
     return `image/${asset.format}`;
  }
  if (typeof asset === 'string') {
    if (/\.svg($|\?)/.test(asset)) return 'image/svg+xml';
    if (/\.png($|\?)/.test(asset)) return 'image/png';
    if (/\.ico($|\?)/.test(asset)) return 'image/x-icon';
    if (/\.webp($|\?)/.test(asset)) return 'image/webp';
  }
  return 'image/x-icon';
};

interface Props {
  title?: string;
  description?: string;
  tex?: boolean;
  navType?: 'home' | 'page'; 
}

const { 
  title = themeConfig.title, 
  description = themeConfig.description,
  tex = false,
  navType = 'page' 
} = Astro.props;

const bodyClass = navType === 'home' ? 'home-page' : 'inner-page';

// --- LAYOUT LOGIC ---
const layout = themeConfig.layout || {};
const globalMarginLeft = layout.margin_left || '140px';
const globalMarginRight = layout.margin_right || globalMarginLeft;

// --- FONTS CONFIGURATION ---
const fonts = themeConfig.fonts || {};

// Level 4: Code Fallback (Generic System Fonts)
const headingFont = fonts.headings || 'sans-serif';
const bodyFont = fonts.body || 'sans-serif';
const navFont = fonts.navigation || 'sans-serif';
const monospaceFont = fonts.monospace || 'monospace';

---

<!DOCTYPE html>
<html lang="en" style={`
  --global-margin-left: ${globalMarginLeft}; 
  --global-margin-right: ${globalMarginRight};
  --heading-font: "${headingFont}";
  --default-font: "${bodyFont}";
  --nav-font: "${navFont}";
  --monospace-font: "${monospaceFont}";
`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={themeConfig.author} />
    
    <ClientRouter />

    {faviconSrc && (
      <link rel="icon" type={getMime(faviconSrc)} href={getAssetUrl(faviconSrc)} />
    )}
    {appleSrc && (
      <link rel="apple-touch-icon" href={getAssetUrl(appleSrc)} />
    )}
    
    <meta name="generator" content={Astro.generator} />

    {/* CRITICAL: Fallback for users without JavaScript.
      Without this, elements with data-aos will remain invisible (opacity: 0).
    */}
    <noscript>
      <style>
        /* 1. Hide the preloader completely if JS is disabled */
        #preloader {
          display: none !important; 
          visibility: hidden !important;
        }
        
        /* 2. Force all animated elements to be visible and reset their positions */
        [data-aos] {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      </style>
    </noscript>
  </head>

  <body class={bodyClass} data-tex={tex}>
    <Navigation isHome={navType === 'home'} />

    <i class="nav-toggle d-lg-none bi bi-list"></i>

    <main class="main">
      <slot />
    </main>

    <Footer />

    <div id="preloader"></div>

    {/* ASTRO 5 BEST PRACTICE:
       1. Remove 'is:inline' so the script is processed as a module (loaded once, cached).
       2. Use 'astro:page-load' to trigger logic on initial visit AND after every transition.
    */}
    <script>
      function onPageLoad() {
        // --- 1. PRELOADER ---
        const preloader = document.getElementById('preloader');
        if (preloader) {
          // Optional: If this is an internal navigation (not a full reload), 
          // you might want to hide it instantly. 
          // For now, we keep the fade behavior for consistency.
          preloader.style.opacity = '0';
          setTimeout(() => { preloader.remove(); }, 600);
        }

        // --- 2. ANIMATIONS (AOS Style) ---
        const aosObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('aos-animate');
              aosObserver.unobserve(entry.target); 
            }
          });
        }, { rootMargin: '0px 0px -50px 0px', threshold: 0.1 });

        document.querySelectorAll('[data-aos]').forEach(el => aosObserver.observe(el));

        // --- 3. SCROLLSPY ---
        const sections = document.querySelectorAll('section');
        const navLinks = document.querySelectorAll('.nav-menu a, .nav-link');

        // Only run ScrollSpy if we actually have sections to spy on
        if (sections.length > 0) {
          const spyObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const id = entry.target.getAttribute('id');
                if (id) {
                  navLinks.forEach(link => link.classList.remove('active'));
                  const activeLink = document.querySelector(`.nav-menu a[href*="#${id}"]`);
                  if (activeLink) activeLink.classList.add('active');
                }
              }
            });
          }, { rootMargin: '-30% 0px -70% 0px' }); // Active when section is near top

          sections.forEach(section => spyObserver.observe(section));
        }
      }

      // Fires on initial load, view transitions, and history navigation.
      document.addEventListener('astro:page-load', onPageLoad);
    </script>

  </body>
</html>