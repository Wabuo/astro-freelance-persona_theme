---
import { getCollection } from 'astro:content';
// Update these paths to go back two levels (../../) instead of one
import BaseLayout from '../../layouts/BaseLayout.astro';
import { themeConfig } from '../../config';

// Components are siblings in the parent folder, so just ../ works for them
import Hero from '../Hero.astro';
import PlainSection from '../sections/PlainSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import CategorySection from '../sections/CategorySection.astro';

// 1. Fetch all sections
const allSections = await getCollection('sections');

// 2. Separate "Hero" from the rest
// We assume the hero settings are in a file named 'hero.md' or '_index.md' inside content/sections/
// Since we are porting, let's look for a section with title "Persona" or order 0.
const heroSection = allSections.find(s => s.slug === 'hero') || {
  data: {
    title: themeConfig.title,
    subtitles: "Welcome"
  }
};

// 3. Filter and Sort the rest
const contentSections = allSections
  .filter(s => s.slug !== 'hero')
  .sort((a, b) => a.data.order - b.data.order);

---

<BaseLayout title={themeConfig.title} navType="home">
  
  <Hero 
    title={heroSection.data.title} 
    subtitles={heroSection.data.subtitles}
    background_image={heroSection.data.background_image} 
/>

  {contentSections.map(async (section) => {
    const { Content } = await section.render();
    
    // We check the 'type' field we added to the schema
    if (section.data.type === 'plain') {
      return (
        <PlainSection 
          slug={section.slug} 
          title={section.data.title} 
          subtitle={section.data.subtitle}
        >
          <Content />
        </PlainSection>
      );
    }
    
    if (section.data.type === 'category') {
      return (
        <CategorySection 
          slug={section.slug} 
          title={section.data.title} 
          subtitle={section.data.subtitle}
        />
      );
    }

    return null;
  })}

  <ContactSection />

</BaseLayout>
