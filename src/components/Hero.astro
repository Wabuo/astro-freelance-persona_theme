---
import { Image } from 'astro:assets';
import { themeConfig } from '../config';

interface Props {
  title: string;
  subtitles?: string;
  background_image?: ImageMetadata; 
}

const { title, subtitles, background_image: explicitImage } = Astro.props;

// --- DYNAMIC BACKGROUND LOGIC ---
let finalImage = explicitImage;
if (!finalImage) {
  const bgGlob = import.meta.glob('/src/assets/img/background.{jpg,jpeg,png,webp,avif,svg}');
  const paths = Object.keys(bgGlob);
  if (paths.length > 0) {
    paths.sort((a, b) => {
      const score = (p: string) => p.endsWith('.jpg') ? 4 : p.endsWith('.png') ? 3 : p.endsWith('.webp') ? 2 : p.endsWith('.svg') ? 1 : 0;
      return score(b) - score(a);
    });
    const imageModule = await bgGlob[paths[0]]();
    finalImage = imageModule.default;
  }
}
// --- END DYNAMIC LOGIC ---
---

<section id="hero" class="hero section">
  {finalImage && (
    <Image 
      src={finalImage} 
      alt="Background"
      class="hero-bg"
      width={1920} 
      height={1080}
      format="webp"
    />
  )}

  <div class="container" data-aos="zoom-out">
    <div class="row justify-content-center">
      <div class="col-lg-9">
        <h2>{title}</h2>
        {subtitles && (
          <p>I'm <span class="typed" data-typed-items={subtitles}></span><span class="typed-cursor">|</span></p>
        )}
      </div>
    </div>
  </div>
</section>

<script>
  // Tiny Typewriter implementation (Zero Dependency)
  const typedEl = document.querySelector('.typed');
  const cursorEl = document.querySelector('.typed-cursor');
  
  if (typedEl) {
    const words = typedEl.getAttribute('data-typed-items')?.split(',') || [];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let typeSpeed = 100;

    const type = () => {
      const currentWord = words[wordIndex];
      
      if (isDeleting) {
        typedEl.textContent = currentWord.substring(0, charIndex - 1);
        charIndex--;
        typeSpeed = 50; // Deleting is faster
      } else {
        typedEl.textContent = currentWord.substring(0, charIndex + 1);
        charIndex++;
        typeSpeed = 100; // Typing is normal
      }

      if (!isDeleting && charIndex === currentWord.length) {
        // Finished typing word, pause then delete
        isDeleting = true;
        typeSpeed = 2000;
        if(cursorEl) cursorEl.classList.add('blinking');
      } else if (isDeleting && charIndex === 0) {
        // Finished deleting, move to next word
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        typeSpeed = 500;
        if(cursorEl) cursorEl.classList.remove('blinking');
      } else {
        if(cursorEl) cursorEl.classList.remove('blinking');
      }

      setTimeout(type, typeSpeed);
    };

    if (words.length > 0) type();
  }
</script>

<style>
  .hero-bg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  
  /* Cursor Blinking Animation */
  .typed-cursor {
    opacity: 1;
    font-weight: 100;
    color: inherit;
    margin-left: 2px;
  }
  .typed-cursor.blinking {
    animation: blink 0.7s infinite;
  }
  @keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>