---
import SectionTitle from '@freelance-persona/components/ui/SectionTitle.astro';

interface Props {
  id: string;
  title: string;
  subtitle?: string;
}
const { id, title, subtitle } = Astro.props;
---

<section id={id} class="plain section">
  <SectionTitle title={title} subtitle={subtitle} />
  
  <div class="container" data-aos="fade-up" data-aos-delay="100">
    <div class="content">
      <slot /> </div>
  </div>
</section>
