---
// src/freelance-persona/components/Footer.astro
import { themeConfig } from "@freelance-persona/config";
import { Icon } from "astro-icon/components";
import { transformIcon } from "@freelance-persona/utils/iconUtils";
import { resolveLink } from "@freelance-persona/utils/linkUtils";
import { parse } from "marked"; // <--- The "real" parser
import { replaceBuildTokens } from "@freelance-persona/utils/buildInfo";

const { title, quote, social_links, copyright, credits } = themeConfig;

// Normalize credits to array for manipulation
const creditsArray = Array.isArray(credits) ? [...credits] : [credits || ""];

// Join lines with explicit break and parse
const finalCreditsString = creditsArray.join(" <br> ");
const creditsHtml = await parse(replaceBuildTokens(finalCreditsString));
---

<footer id="footer" class="footer position-relative">
  <div class="container">
    <h3 class="sitename">{title}</h3>
    <p class="quote">{quote}</p>

    <div class="social-links d-flex justify-content-center">
      {
        social_links.map((link: any) => (
          <a
            href={link.url}
            aria-label={`Link to my ${link.name} profile`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name={transformIcon(link.icon_class)} aria-hidden="true" />
          </a>
        ))
      }
    </div>

    <div class="container">
      <div class="copyright">
        <span set:html={copyright} />
        {
          themeConfig.legal?.enabled && (
            <>
              <span class="legal-separator mx-2">|</span>
              <a href={resolveLink("legal/legal-notice")} class="legal-link">
                {themeConfig.legal.link_text || "Legal Notice"}
              </a>
            </>
          )
        }
        {
          themeConfig.legal?.privacy_enabled && (
            <>
              <span class="legal-separator mx-2">|</span>
              <a href={resolveLink("legal/privacy-policy")} class="legal-link">
                {themeConfig.legal.privacy_link_text || "Privacy Policy"}
              </a>
            </>
          )
        }
      </div>
      {/* Render the fully parsed HTML */}
      <div class="credits" set:html={creditsHtml} />
    </div>
  </div>
</footer>
