---
// src/components/Navigation.astro
// Two-element navigation architecture: Desktop nav + Mobile popover nav
import NavLinks from "@freelance-persona/components/ui/_NavLinks.astro";

// Props: isHome determines link behavior and styling
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;
---

<!-- Desktop Navigation (always visible on desktop, hidden on mobile via CSS) -->
<header
  class={`header desktop-nav d-flex flex-column justify-content-center ${
    isHome ? "is-home" : "is-inner"
  }`}
>
  <NavLinks isHome={isHome} />
</header>

<!-- Mobile Navigation (popover drawer, hidden on desktop via CSS) -->
<header
  id="mobile-nav"
  popover="auto"
  class={`header mobile-nav d-flex flex-column justify-content-center ${
    isHome ? "is-home" : "is-inner"
  }`}
>
  <!-- Close button inside popover (above backdrop, in top layer) -->
  <button
    popovertarget="mobile-nav"
    popovertargetaction="hide"
    class="nav-close"
    aria-label="Close navigation menu"
  >
    <i class="bi bi-x"></i>
  </button>
  <NavLinks isHome={isHome} isMobile={true} />
</header>

<!-- Mobile Toggle Button (visible only on mobile) -->
<button
  popovertarget="mobile-nav"
  class="nav-toggle"
  aria-label="Toggle navigation menu"
>
  <i class="hamburger-icon bi bi-list"></i>
  <i class="close-icon bi bi-x"></i>
</button>

<style>
  /* Toggle Button Styles - Global to apply to _NavLinks child component */
  :global(.theme-toggle) {
    background: none;
    border: none;
    color: var(--nav-color);
    width: 100%;
    display: flex;
    align-items: center;
    padding: 10px 15px; /* Match nav links padding */
    cursor: pointer;
    font-size: 16px;
    font-family: var(--nav-font);
    transition: 0.3s;
  }

  :global(.theme-toggle:hover) {
    color: var(--nav-hover-color);
  }

  :global(.theme-toggle i) {
    font-size: 20px; /* Slightly refined size */
    padding-right: 8px;
  }

  /* Desktop Improvements */
  @media (min-width: 768px) {
    /* Topnav Specifics (Inner Pages) */
    :global(.is-inner .theme-toggle) {
      width: auto;
      padding: 1rem 0 1rem 1rem; /* Left padding only to separate from last link */
      margin-left: 0.5rem;
      border-left: 1px solid
        color-mix(in srgb, var(--default-color), transparent 85%);
    }

    /* Hide text on desktop for both Topnav and Sidenav (Matches _navigation-index behavior) */
    :global(.theme-toggle span) {
      display: none;
    }

    /* Refine Icon for Inner Pages */
    :global(.is-inner .theme-toggle i) {
      padding-right: 0;
      font-size: 1.25rem;
    }

    /* Sidenav Specifics (Home Page) - Align with standard links */
    :global(.is-home .theme-toggle) {
      justify-content: flex-start;
      margin-bottom: 0.5rem;

      /* MATCHING SIDEBAR LINK STYLES (_navigation-index.scss) */
      /* User Request: No background "pill" to avoid looking like a page, but keep dimensions for alignment */
      background: transparent;
      border-radius: 3.125rem; /* 50px */
      height: var(
        --nav-icon-size,
        3.5rem
      ); /* Fallback to standard size if var missing */
      width: 100%;
      max-width: var(
        --nav-icon-size,
        3.5rem
      ); /* CRITICAL: Constrain width to circle on desktop */
      padding: 0.625rem 1.125rem;

      /* Ensure proper centering like links */
      display: flex;
      align-items: center;
    }

    /* Hover State for Sidenav Toggle */
    :global(.is-home .theme-toggle:hover) {
      background: var(--nav-hover-color);
      color: var(--contrast-color);
    }

    :global(.is-home .theme-toggle i) {
      font-size: 1.25rem;
      /* margin-left removed: Padding (1.125rem) already centers the 20px icon in 56px container perfectly */
    }
  }

  /* Active state for button if needed to match links */
  :global(.theme-toggle:focus) {
    outline: none;
  }
</style>

<script>
  // Navigation Interactions

  // 1. Mobile Navigation (Popover API)
  const initMobileNav = () => {
    const mobileNav = document.getElementById("mobile-nav");
    const toggleBtn = document.querySelector(".nav-toggle");

    // Close popover when a nav link is clicked (for same-page anchor navigation)
    document.querySelectorAll("#navmenu-mobile a").forEach((link) => {
      link.addEventListener("click", () => {
        if (mobileNav && mobileNav.matches(":popover-open")) {
          mobileNav.hidePopover();
        }
      });
    });

    // Icon swap via toggle event
    if (toggleBtn && mobileNav) {
      mobileNav.addEventListener("toggle", (e) => {
        const hamburger = toggleBtn.querySelector(".hamburger-icon");
        const closeIcon = toggleBtn.querySelector(".close-icon");
        if (hamburger && closeIcon) {
          if (e.newState === "open") {
            (hamburger as HTMLElement).style.display = "none";
            (closeIcon as HTMLElement).style.display = "block";
          } else {
            (hamburger as HTMLElement).style.display = "block";
            (closeIcon as HTMLElement).style.display = "none";
          }
        }
      });
    }
  };

  // Run on load
  document.addEventListener("astro:page-load", initMobileNav);
  document.addEventListener("DOMContentLoaded", initMobileNav);

  // 2. ScrollSpy (Highlight active link on scroll)
  const initScrollSpy = () => {
    const isHomePage = document.body.classList.contains("home-page");

    if (isHomePage) {
      // Target both desktop and mobile nav links
      const navLinks = document.querySelectorAll(
        "#navmenu a, #navmenu-mobile a"
      );
      const sections = document.querySelectorAll("section");

      const updateActiveLink = () => {
        let position = window.scrollY + 200;
        let currentActiveId: string | null = null;

        sections.forEach((section) => {
          if (position >= section.offsetTop) {
            const hasLink = Array.from(navLinks).some(
              (link) => link.getAttribute("href") === "#" + section.id
            );
            if (hasLink) {
              currentActiveId = section.id;
            }
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("active");
          if (
            currentActiveId &&
            link.getAttribute("href") === "#" + currentActiveId
          ) {
            link.classList.add("active");
          }
        });

        // Edge case: Top of page (Hero)
        if (window.scrollY < 100) {
          navLinks.forEach((link) => link.classList.remove("active"));
          document
            .querySelectorAll(
              '#navmenu a[href="#hero"], #navmenu-mobile a[href="#hero"]'
            )
            .forEach((link) => {
              link.classList.add("active");
            });
        }
      };

      updateActiveLink();
      document.addEventListener("scroll", updateActiveLink);

      document.addEventListener(
        "astro:before-swap",
        () => {
          document.removeEventListener("scroll", updateActiveLink);
        },
        { once: true }
      );
    }
  };

  // 3. Theme Toggle Logic (handles both desktop and mobile toggles)
  const initThemeToggle = () => {
    const toggleBtns = document.querySelectorAll(
      "#theme-toggle, #theme-toggle-mobile"
    );
    const themeIcons = document.querySelectorAll(
      "#theme-icon, #theme-icon-mobile"
    );

    if (toggleBtns.length > 0 && themeIcons.length > 0) {
      const updateIcon = (theme: string) => {
        themeIcons.forEach((icon) => {
          if (theme === "dark") {
            icon.classList.remove("bi-moon");
            icon.classList.add("bi-sun");
          } else {
            icon.classList.remove("bi-sun");
            icon.classList.add("bi-moon");
          }
        });
      };

      const getEffectiveTheme = () => {
        const attr = document.documentElement.getAttribute("data-theme");
        if (attr) return attr;
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      // Initial Icon State
      updateIcon(getEffectiveTheme());

      toggleBtns.forEach((toggleBtn) => {
        // Prevent double binding
        if (toggleBtn.hasAttribute("data-init")) return;
        toggleBtn.setAttribute("data-init", "true");

        toggleBtn.addEventListener("click", () => {
          const currentTheme = getEffectiveTheme();
          const newTheme = currentTheme === "dark" ? "light" : "dark";
          document.documentElement.setAttribute("data-theme", newTheme);
          localStorage.setItem("theme", newTheme);
          updateIcon(newTheme);
        });
      });
    }
  };

  // Run on every page load (Client Router compatible)
  document.addEventListener("astro:page-load", initThemeToggle);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initThemeToggle);
  } else {
    initThemeToggle();
  }

  document.addEventListener("astro:page-load", initScrollSpy);
</script>
