---
// src/components/Navigation.astro
import { getCollection } from "astro:content";
import { themeConfig } from "@freelance-persona/config";
import LanceIcon from "@freelance-persona/components/ui/LanceIcon.astro";

// Props: isHome determines link behavior and styling
interface Props {
  isHome?: boolean;
}
const { isHome = false } = Astro.props;

// Fetch and sort sections
const sections = await getCollection("sections");
const sortedSections = sections.sort((a, b) => a.data.order - b.data.order);

// Helper to determine the href
const getLink = (id: string) => {
  if (isHome) {
    return `#${id}`; // Scroll to section
  } else {
    // For inner pages, link to the homepage anchor
    return `/#${id}`;
  }
};
---

<header id="header" class="header d-flex flex-column justify-content-center">
  <nav id="navmenu" class="navmenu">
    <ul>
      <li>
        <a
          href={isHome ? "#hero" : "/"}
          class={isHome ? "active" : ""}
          aria-label="Home"
        >
          <i class="bi bi-house navicon"></i>
          <span>Home</span>
        </a>
      </li>

      {
        sortedSections.map((section) => {
          // Determine if this section is "active" based on current URL
          // 1. Exact match for single-page sections (e.g. #hero on home) - handled by scrollspy script mostly
          // 2. Path prefix match for inner pages (e.g. /blogs/xyz -> highlights blog-categories)

          let isActive = false;
          const currentPath = Astro.url.pathname;
          // Use custom_id if available (e.g. "blogs" instead of "blog-categories")
          const sectionId = (section.data as any).custom_id || section.id;

          // Special mapping for known sections with different URL structures
          // If the section ID is "blogs" (custom or default) and we are on a /blogs/ path
          if (
            (sectionId === "blog-categories" || sectionId === "blogs") &&
            (currentPath.startsWith("/blogs") ||
              currentPath.startsWith("/blog/"))
          ) {
            isActive = true;
          }
          // Generic fallback: if path matches section id (e.g. /projects/...)
          else if (currentPath.startsWith(`/${sectionId}`)) {
            isActive = true;
          }

          return (
            // Only show sections that have an icon (avoids listing non-menu items)
            // Fix: Hide 'lance-icon' (Hero/Brand) on inner pages where top-nav is used
            section.data.icon_class &&
            (isHome || section.data.icon_class !== "lance-icon") && (
              <li>
                <a
                  href={getLink(sectionId)}
                  aria-label={section.data.title}
                  class={!isHome && isActive ? "active" : ""}
                >
                  {section.data.icon_class === "lance-icon" ? (
                    <LanceIcon class="navicon" />
                  ) : (
                    <i class={`${section.data.icon_class} navicon`} />
                  )}
                  <span>{section.data.title}</span>
                </a>
              </li>
            )
          );
        })
      }

      {
        themeConfig.contact_infos && (
          <li>
            <a href={getLink("contact")} aria-label="Contact">
              <i class="bi bi-envelope navicon" />
              <span>Contact</span>
            </a>
          </li>
        )
      }

      {/* Theme Toggle */}
      <li>
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Toggle Dark Mode"
        >
          <i class="bi bi-moon navicon" id="theme-icon"></i>
          <span>Theme</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<style>
  /* Toggle Button Styles */
  .theme-toggle {
    background: none;
    border: none;
    color: var(--nav-color);
    width: 100%;
    display: flex;
    align-items: center;
    padding: 10px 15px; /* Match nav links padding */
    cursor: pointer;
    font-size: 16px;
    font-family: var(--nav-font);
    transition: 0.3s;
  }

  .theme-toggle:hover {
    color: var(--nav-hover-color);
  }

  .theme-toggle i {
    font-size: 24px;
    padding-right: 8px;
  }

  /* Active state for button if needed to match links */
  .theme-toggle:focus {
    outline: none;
  }
</style>

<script>
  // Navigation Interactions

  // 1. Mobile Navigation Toggle
  const toggleBtn = document.querySelector(".nav-toggle");
  const header = document.querySelector(".header");

  if (toggleBtn && header) {
    toggleBtn.addEventListener("click", () => {
      header.classList.toggle("navmenu-show");
      toggleBtn.classList.toggle("bi-list");
      toggleBtn.classList.toggle("bi-x");
    });
  }

  // 2. ScrollSpy (Highlight active link on scroll)
  // Refactored for Astro View Transitions compatibility
  const initScrollSpy = () => {
    // Only run this if we are on the home page (single page scroll)
    const isHomePage = document.body.classList.contains("home-page");

    if (isHomePage) {
      const navLinks = document.querySelectorAll("#navmenu a");
      const sections = document.querySelectorAll("section");

      const updateActiveLink = () => {
        let position = window.scrollY + 200; // Offset for better triggering
        let currentActiveId = null;

        // Find the last section that we've scrolled past AND has a nav link
        // This ensures "sticky" active state for sections without menu items (like filtered-posts)
        sections.forEach((section) => {
          if (position >= section.offsetTop) {
            // Check if this section has a corresponding nav link
            const hasLink = Array.from(navLinks).some(
              (link) => link.getAttribute("href") === "#" + section.id,
            );

            if (hasLink) {
              currentActiveId = section.id;
            }
          }
        });

        // Apply active class
        navLinks.forEach((link) => {
          link.classList.remove("active");
          if (
            currentActiveId &&
            link.getAttribute("href") === "#" + currentActiveId
          ) {
            link.classList.add("active");
          }
        });

        // Edge case: Top of page (Hero)
        if (window.scrollY < 100) {
          navLinks.forEach((link) => link.classList.remove("active"));
          const homeLink = document.querySelector('#navmenu a[href="#hero"]');
          // Safety check: ensure homeLink exists before accessing classList
          if (homeLink) homeLink.classList.add("active");
        }
      };

      // Run immediately to set initial state
      updateActiveLink();

      // Attach listener
      document.addEventListener("scroll", updateActiveLink);

      // Cleanup: Remove listener when leaving the page (soft nav)
      document.addEventListener(
        "astro:before-swap",
        () => {
          document.removeEventListener("scroll", updateActiveLink);
        },
        { once: true },
      );
    }
  };

  // 3. Theme Toggle Logic
  const initThemeToggle = () => {
    const toggleBtn = document.getElementById("theme-toggle");
    const themeIcon = document.getElementById("theme-icon");

    if (toggleBtn && themeIcon) {
      // Prevent double binding
      if (toggleBtn.hasAttribute("data-init")) return;
      toggleBtn.setAttribute("data-init", "true");

      const updateIcon = (theme) => {
        if (theme === "dark") {
          themeIcon.classList.remove("bi-moon");
          themeIcon.classList.add("bi-sun");
        } else {
          themeIcon.classList.remove("bi-sun");
          themeIcon.classList.add("bi-moon");
        }
      };

      // Determine effective current theme
      const getEffectiveTheme = () => {
        const attr = document.documentElement.getAttribute("data-theme");
        if (attr) return attr;
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      // Initial Icon State
      updateIcon(getEffectiveTheme());

      toggleBtn.addEventListener("click", () => {
        const currentTheme = getEffectiveTheme();
        const newTheme = currentTheme === "dark" ? "light" : "dark";

        // Update Attribute
        document.documentElement.setAttribute("data-theme", newTheme);

        // Save Preference
        localStorage.setItem("theme", newTheme);

        // Update Icon
        updateIcon(newTheme);
      });
    }
  };

  // Run on every page load (Client Router compatible)
  document.addEventListener("astro:page-load", initThemeToggle);
  // Also run on initial load if astro:page-load doesn't fire immediately (fallback)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initThemeToggle);
  } else {
    initThemeToggle();
  }

  // Run on every soft or hard navigation
  document.addEventListener("astro:page-load", initScrollSpy);
</script>
