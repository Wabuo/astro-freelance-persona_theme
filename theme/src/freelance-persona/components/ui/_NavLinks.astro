// src/components/ui/NavLinks.astro
// Shared navigation links component - used by both desktop and mobile nav
import { getCollection } from "astro:content";
import { themeConfig } from "@freelance-persona/config";
import { Icon } from "astro-icon/components";
import { transformIcon } from "@freelance-persona/utils/iconUtils";
import LanceIcon from "@freelance-persona/components/ui/LanceIcon.astro";

interface Props {
  isHome?: boolean;
  isMobile?: boolean;
}
const { isHome = false, isMobile = false } = Astro.props;
const toggleId = isMobile
  ? "theme-menu-toggle-mobile"
  : "theme-menu-toggle-desktop";

// Fetch and sort sections
const sections = await getCollection("sections");
const sortedSections = sections.sort((a, b) => a.data.order - b.data.order);

// Helper to determine the href
const getLink = (id: string) => {
  if (isHome) {
    return `#${id}`; // Scroll to section
  } else {
    // For inner pages, link to the homepage anchor
    return `/#${id}`;
  }
};
---

<nav id={isMobile ? "navmenu-mobile" : "navmenu"} class="navmenu">
  <ul>
    <li>
      <a
        href={isHome ? "#hero" : "/"}
        class={isHome ? "active" : ""}
        aria-label="Home"
      >
        <Icon name="bi:house" class="navicon" />
        <span>Home</span>
      </a>
    </li>

    {
      sortedSections.map((section) => {
        // Determine if this section is "active" based on current URL
        let isActive = false;
        const currentPath = Astro.url.pathname;
        const sectionId = (section.data as any).custom_id || section.id;

        // Special mapping for known sections with different URL structures
        if (
          (sectionId === "blog-categories" || sectionId === "blogs") &&
          (currentPath.startsWith("/blogs") || currentPath.startsWith("/blog/"))
        ) {
          isActive = true;
        } else if (currentPath.startsWith(`/${sectionId}`)) {
          isActive = true;
        }

        return (
          // Only show sections that have an icon
          // Hide 'lance-icon' (Hero/Brand) on inner pages where top-nav is used
          section.data.icon_class &&
          (isHome || section.data.icon_class !== "lance-icon") && (
            <li>
              <a
                href={getLink(sectionId)}
                aria-label={section.data.title}
                class={!isHome && isActive ? "active" : ""}
              >
                {section.data.icon_class === "lance-icon" ? (
                  <LanceIcon class="navicon" />
                ) : (
                  <Icon name={transformIcon(section.data.icon_class)} class="navicon" />
                )}
                <span>{section.data.title}</span>
              </a>
            </li>
          )
        );
      })
    }

    {/* Theme Toggle (Dropdown Menu - Pure CSS Hover + Native Click) */}
    <li class="dropdown theme-toggle-container">
      <!-- Invisible backdrop for light dismiss click-outside to close natively -->
      <label for={toggleId} class="theme-menu-backdrop" aria-hidden="true"
      ></label>
      <input
        type="checkbox"
        id={toggleId}
        class="sr-only theme-menu-toggle-checkbox"
        aria-label="Theme Preferences"
      />

      <label for={toggleId} class="theme-toggle">
        <span class="theme-icon-container">
          <Icon name="bi:circle-half" class="navicon theme-icon-os" />
          <Icon name="bi:sun" class="navicon theme-icon-light" />
          <Icon name="bi:moon" class="navicon theme-icon-dark" />
        </span>
        <span class="theme-text-label">Theme</span>
        <Icon name="bi:chevron-down" class="toggle-dropdown" />
      </label>
      <ul class="theme-dropdown-menu">
        <li>
          <label
            for="theme-os"
            class="theme-toggle-label dropdown-item theme-label-os"
          >
            <Icon name="bi:circle-half" class="navicon" /><span class="theme-name"
              >Auto</span
            >
            <Icon name="bi:toggle-off" class="toggle-icon toggle-off" />
            <Icon
              name="bi:toggle-on" class="toggle-icon toggle-on"
              style="display: none;" />
          </label>
        </li>
        <li>
          <label
            for="theme-light"
            class="theme-toggle-label dropdown-item theme-label-light"
          >
            <Icon name="bi:sun" class="navicon" /><span class="theme-name"
              >Light</span
            >
            <Icon name="bi:toggle-off" class="toggle-icon toggle-off" />
            <Icon
              name="bi:toggle-on" class="toggle-icon toggle-on"
              style="display: none;" />
          </label>
        </li>
        <li>
          <label
            for="theme-dark"
            class="theme-toggle-label dropdown-item theme-label-dark"
          >
            <Icon name="bi:moon" class="navicon" /><span class="theme-name"
              >Dark</span
            >
            <Icon name="bi:toggle-off" class="toggle-icon toggle-off" />
            <Icon
              name="bi:toggle-on" class="toggle-icon toggle-on"
              style="display: none;" />
          </label>
        </li>
      </ul>
    </li>
  </ul>
</nav>
