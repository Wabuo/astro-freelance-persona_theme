---
// src/components/sections/ContactSection.astro
import { themeConfig } from "@freelance-persona/config";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";

const { entry } = Astro.props;
if (!entry) throw new Error('ContactSection requires an "entry" prop.');

const {
  title,
  subtitle,
  contact_items = [],
  nudge_x,
  nudge_y,
  content_scale,
  delay,
} = entry.data;

// MIXER LOGIC: Resolve Defaults
// Level 2 (Component Role) & Level 3 (User Config) resolution
const resolvedItems = contact_items.map((item) => {
  let content = item.value;

  switch (item.value) {
    case "theme_email":
      content = themeConfig.email;
      break;
    case "theme_phone":
      content = themeConfig.phone;
      break;
    case "theme_address":
      content = themeConfig.address;
      break;
    case "theme_author":
      content = themeConfig.author;
      break;
    default:
      content = item.value;
  }

  // Validate: If content ends up empty (e.g. themeConfig var was empty), warn user
  if (!content) {
    console.warn(
      `⚠️ [freelance-persona] Contact item "${item.label}" has no value. It is set to "${item.value}" which resolved to an empty string. Please check your freelance-persona.config.ts or contact.md.`
    );
  }

  return { ...item, content };
});

// FORM PROVIDER LOGIC
// Defaults to 'formspark' via optional chain fallback or explicit config
const provider = themeConfig.contact_form?.provider || "formspark";

// Resolve Access Key
const accessKey = themeConfig.contact_form?.access_key;

// Resolve Action URL
let actionUrl = themeConfig.contact_form?.action || "";
let formMethod = "POST";

// Provider Specific Setup
switch (provider) {
  case "formspark":
    if (!actionUrl && accessKey) {
      actionUrl = `https://submit-form.com/${accessKey}`;
    }
    break;
  case "web3forms":
    if (!actionUrl) {
      actionUrl = "https://api.web3forms.com/submit";
    }
    break;
  case "ntfy":
    // Ntfy Logic: Server + Topic
    if (!actionUrl) {
      const server = themeConfig.contact_form?.ntfy_server || "https://ntfy.sh";
      const topic = themeConfig.contact_form?.ntfy_topic;
      // Force HTTPS unless strict local dev override (left as exercise for user manual config)
      // We default to secure.
      if (!server.startsWith("http")) {
        // user just put 'ntfy.sh'
        actionUrl = `https://${server}/${topic}`;
      } else {
        actionUrl = `${server}/${topic}`;
      }
    }
    break;
  case "netlify":
    actionUrl = "/"; // Netlify handles submission on same-page POST
    break;
  case "mailto":
    actionUrl = `mailto:${themeConfig.email}`;
    formMethod = "POST"; // Standard form behavior for mailto
    break;
  case "custom":
    // actionUrl must be provided in config
    break;
}

const showForm = provider !== "custom" || !!actionUrl;

// Animation Config
const headingDelay = themeConfig.visuals?.delays?.heading || 100;
const contentDelay = themeConfig.visuals?.delays?.content || 200;
const staggerDelay = themeConfig.visuals?.delays?.stagger || 100;

// Visual Overrides CSS
const sectionStyle = `
  ${nudge_x ? `--nudge-x: ${nudge_x};` : ""}
  ${nudge_y ? `--nudge-y: ${nudge_y};` : ""}
  ${content_scale ? `--content-scale: ${content_scale};` : ""}
`;
---

<section id={entry.id} class="contact section" style={sectionStyle}>
  <SectionTitle title={title} subtitle={subtitle} delay={headingDelay} />

  <div class="container" data-reveal data-reveal-delay={delay || contentDelay}>
    <div class="row gy-4">
      <div class={showForm ? "col-lg-4" : "col-lg-8 offset-lg-4"}>
        <div class="info-list d-flex flex-column gap-4">
          {
            resolvedItems.map((info, index) => (
              <>
                {info.type === "email" ? (
                  <a
                    href={`mailto:${info.content}`}
                    class="info-item d-flex email-wrapper"
                    data-reveal="fade-up"
                    data-reveal-delay={
                      (delay || contentDelay) + index * staggerDelay
                    }
                  >
                    <i class={info.icon} />
                    <div>
                      <h3>{info.label}</h3>
                      <p>{info.content}</p>
                    </div>
                  </a>
                ) : (
                  <div
                    class="info-item d-flex"
                    data-reveal="fade-up"
                    data-reveal-delay={
                      (delay || contentDelay) + index * staggerDelay
                    }
                  >
                    <i class={info.icon} />
                    <div>
                      <h3>{info.label}</h3>
                      <p>{info.content}</p>
                    </div>
                  </div>
                )}
              </>
            ))
          }
        </div>
      </div>

      {
        showForm && (
          <div class="col-lg-8">
            <form
              action={actionUrl}
              method={formMethod}
              enctype={provider === "mailto" ? "text/plain" : undefined}
              class="contact-form"
              data-reveal="fade-up"
              data-reveal-delay="400"
              data-provider={provider}
              data-netlify={provider === "netlify" ? "true" : undefined}
              name={provider === "netlify" ? "contact" : undefined}
            >
              {/* Access Key input only needed for Formspark/Web3 if not in URL */}
              {provider === "web3forms" && (
                <input type="hidden" name="access_key" value={accessKey} />
              )}

              {/* Ntfy Headers (Hidden inputs for NoScript fallback) can vary,
                   but Ntfy generally supports headers or JSON.
                   HTML Form POST to ntfy.sh sends body.
                   We rely on JS adapter for advanced Title/Priority.
               */}

              <div class="row gy-4">
                <div class="col-md-6">
                  <div class="input-box">
                    <input
                      type="text"
                      name="name"
                      id="name-field"
                      autocomplete="name"
                      required
                    />
                    <label for="name-field" class="label">
                      Your Name
                    </label>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="input-box">
                    <input
                      type="email"
                      name="email"
                      id="email-field"
                      autocomplete="email"
                      required
                    />
                    <label for="email-field" class="label">
                      Your Email
                    </label>
                  </div>
                </div>

                <div class="col-md-12">
                  <div class="input-box">
                    <input
                      type="text"
                      name="subject"
                      id="subject-field"
                      autocomplete="off"
                      required
                    />
                    <label for="subject-field" class="label">
                      Subject
                    </label>
                  </div>
                </div>

                <div class="col-md-12">
                  <div class="input-box">
                    <textarea
                      name="message"
                      rows="6"
                      id="message-field"
                      autocomplete="off"
                      required
                    />
                    <label for="message-field" class="label">
                      Message
                    </label>
                  </div>
                </div>

                <div class="col-md-12 text-center">
                  <div class="loading">Loading</div>
                  <div class="error-message" />
                  <div class="sent-message">
                    Your message has been sent. Thank you!
                  </div>
                  <button type="submit">Send Message</button>
                </div>
              </div>
            </form>
          </div>
        )
      }
    </div>
  </div>
</section>

<script>
  // Progressive Improvement Adapter
  // This script runs only if JS is enabled, intercepting the form submission.
  const forms = document.querySelectorAll(
    "form.contact-form",
  ) as NodeListOf<HTMLFormElement>;

  forms.forEach((form) => {
    // If provider is mailto or netlify, we might want default behavior or specific handling.
    // Netlify works best with default submission or specific fetch.
    // Mailto must work with default submission.
    const provider = form.dataset.provider;

    if (provider === "mailto") return; // Let browser handle mailto
    if (provider === "netlify") return; // Let Netlify standard form handling (or add AJAX later if requested)

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const loading = form.querySelector(".loading") as HTMLElement;
      const errorMessage = form.querySelector(".error-message") as HTMLElement;
      const sentMessage = form.querySelector(".sent-message") as HTMLElement;

      if (loading) loading.style.display = "block";
      if (errorMessage) errorMessage.style.display = "none";
      if (sentMessage) sentMessage.style.display = "none";

      const formData = new FormData(form);
      const action = form.getAttribute("action");

      // payload construction
      let body: any = formData;
      let headers: HeadersInit = {
        Accept: "application/json",
      };

      // Provider Specific Transformations
      if (provider === "web3forms" || provider === "formspark") {
        // These accept JSON best
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);
        body = json;
        headers = {
          "Content-Type": "application/json",
          Accept: "application/json",
        };
      }

      try {
        const response = await fetch(action!, {
          method: "POST", // Always POST (except Custom override maybe? but assuming POST)
          body: body instanceof FormData ? body : body,
          headers: headers,
        });

        if (response.ok) {
          if (loading) loading.style.display = "none";
          if (sentMessage) sentMessage.style.display = "block";
          form.reset();
        } else {
          throw new Error(`${response.status} ${response.statusText}`);
        }
      } catch (error: any) {
        if (loading) loading.style.display = "none";
        if (errorMessage) {
          errorMessage.textContent = error.message || "Form submission failed.";
          errorMessage.style.display = "block";
        }
      }
    });
  });
</script>

<style>
  .contact.section {
    transform: translate(var(--nudge-x, 0), var(--nudge-y, 0))
      scale(var(--content-scale, 1));
  }

  /* 1. RESET: Make the anchor behave like a block div (no default link color) */
  .email-wrapper {
    text-decoration: none;
    color: inherit; /* Inherit text color from parent (usually dark/white) */
    cursor: pointer;
    transition: 0.3s;
  }

  /* 2. TEXT COLOR: The email address is ALWAYS accent color */
  .email-wrapper p {
    color: var(--accent-color);
    margin-bottom: 0;
    transition: 0.3s;
  }

  /* 3. HOVER STATE: Underline the text when hovering the wrapper */
  .email-wrapper:hover p {
    text-decoration: underline;
    text-decoration-color: var(--accent-color);
    text-underline-offset: 0.2rem; /* 3px -> ~0.2rem */
  }

  /* Optional: Light up the icon background on hover too (standard theme behavior) */
  .email-wrapper:hover i {
    background: var(--accent-color);
    color: var(--contrast-color);
  }
</style>
