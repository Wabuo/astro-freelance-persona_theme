---
// src/freelance-persona/components/templates/BlogPostTemplate.astro
import { getCollection } from "astro:content";
import BaseLayout from "@freelance-persona/layouts/BaseLayout.astro";
import { Image, getImage } from "astro:assets";
import { slugify } from "@freelance-persona/utils/slugify";
import { resolveLink } from "@freelance-persona/utils/linkUtils";
import Breadcrumbs from "@freelance-persona/components/ui/Breadcrumbs.astro";
import BlogSidebar from "@freelance-persona/components/blog/BlogSidebar.astro";
import ShareMenu from "@freelance-persona/components/ui/ShareMenu.astro";
import ImageAttribution from "@freelance-persona/components/ui/ImageAttribution.astro";
import { Icon } from "astro-icon/components";

const { post } = Astro.props;

// REFACTOR: Now using shared utility
// const slugify = (text: string) => ...

// Fetch sections to find the "blogs" section or "recent posts" fallback
const sections = await getCollection("sections");
const blogsSection = sections.find(
  (s: any) => s.data.type === "blog_categories",
);
const recentPostsSection = sections.find((s: any) => s.id === "recent_posts");

// Determine the primary parent section for breadcrumbs
// Priority: Blog Categories > Recent Posts
const parentSection = blogsSection || recentPostsSection;

let categoryCrumb = null;

if (blogsSection && blogsSection.data.categories && post.data.tags) {
  // Find which category this post belongs to based on shared tags
  const matchedCategory = blogsSection.data.categories.find((cat: any) =>
    cat.tags.some((tag: string) => post.data.tags.includes(tag)),
  );

  if (matchedCategory) {
    categoryCrumb = {
      label: matchedCategory.title,
      href: resolveLink(`blogs/${slugify(matchedCategory.title)}`),
    };
  }
}

// Helper for approximate reading time
const wordCount = post.body ? post.body.split(/\s+/g).length : 0;
const readingTime = Math.ceil(wordCount / 200);

const crumbs: { label: string; href?: string }[] = [
  { label: "Home", href: resolveLink("/") },
];

if (parentSection) {
  // Use custom_id if available, otherwise default to section id
  const sectionId = (parentSection.data as any).custom_id || parentSection.id;
  crumbs.push({
    label: parentSection.data.title,
    href: `${import.meta.env.BASE_URL}#${sectionId}`,
  });
}

if (categoryCrumb) {
  crumbs.push(categoryCrumb);
}

crumbs.push({ label: post.data.title });

// Optimize/resolve the post thumbnail URL for preloading in <head>
const optimizedThumbnail = post.data.thumbnail
  ? await getImage({
      src: post.data.thumbnail,
      format: post.data.thumbnail.format === 'svg' ? 'svg' : 'webp',
      width: 1100,
      quality: "high",
    })
  : null;
---

<BaseLayout title={post.data.title} navType="page" tex={post.data.tex || false} preloadImageUrl={optimizedThumbnail?.src}>
  <Breadcrumbs crumbs={crumbs} showTitle={false} />

  <div class="container">
    <div class="row">
      <section id="blog-post" class="blog-post section col-lg-8">
        <div class="container" data-reveal="fade-up">
          <article
            class="article"
            style="
            background-color: var(--surface-color, #ffffff); 
            border-radius: var(--img-border-radius); 
            padding: var(--spacing-md);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
          "
          >
            {
              post.data.thumbnail && (
                <div class="post-img">
                  <Image
                    src={post.data.thumbnail}
                    alt={post.data.title}
                    class="img-fluid"
                    width={1100}
                    quality="high"
                    format={post.data.thumbnail.format === 'svg' ? 'svg' : 'webp'}
                    loading="eager"
                    decoding="sync"
                    fetchpriority="high"
                  />
                  {/* Attribution overlay */}
                  <ImageAttribution
                    img_credit={post.data.img_credit}
                    img_copyright={post.data.img_copyright}
                    img_license={post.data.img_license}
                  />
                </div>
              )
            }

            <div class="post-header">
              <h1 class="post-title">{post.data.title}</h1>

              <div class="post-tags">
                {
                  post.data.tags &&
                    post.data.tags.map((tag: string) => (
                      <span class="tag">{tag.toLowerCase()}</span>
                    ))
                }
              </div>

              <div class="meta-top-divider"></div>

              <div class="meta-top">
                <div class="d-flex justify-content-between">
                  <ul id="info" class="d-flex list-unstyled m-0">
                    <li class="d-flex align-items-center me-4">
                      <Icon name="bi:calendar-event" class="me-2" />
                      <time
                        >{
                          post.data.date.toLocaleDateString("en-GB", {
                            day: "2-digit",
                            month: "short",
                            year: "numeric",
                          })
                        }
                      </time>
                    </li>
                    <li class="d-flex align-items-center">
                      <Icon name="bi:hourglass-split" class="me-2" />
                      <time>{readingTime} min read</time>
                    </li>
                  </ul>

                  <ul id="action" class="d-flex list-unstyled m-0">
                    <li class="d-flex align-items-center">
                      <ShareMenu
                        url={Astro.site
                          ? new URL(Astro.url.pathname, Astro.site).toString()
                          : Astro.url.href}
                        title={post.data.title}
                        description={post.data.description}
                      />
                    </li>
                  </ul>
                </div>
              </div>
              <div class="meta-top-divider"></div>
            </div>

            <div class={`post-content ${post.data.layout_style === "science" ? "science-layout" : ""}`}>
              <slot />
            </div>
          </article>
        </div>
      </section>

      <BlogSidebar />
    </div>
  </div>
</BaseLayout>
