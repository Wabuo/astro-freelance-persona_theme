---
// src/freelance-persona/components/templates/BlogPostTemplate.astro
import { getCollection } from "astro:content";
import BaseLayout from "@freelance-persona/layouts/BaseLayout.astro";
import Breadcrumbs from "@freelance-persona/components/ui/Breadcrumbs.astro";
import BlogSidebar from "@freelance-persona/components/blog/BlogSidebar.astro";

const { post } = Astro.props;

// Helper to slugify category names
const slugify = (text: string) =>
  text
    .toString()
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");

// Fetch sections to find the "blogs" section or "recent posts" fallback
const sections = await getCollection("sections");
const blogsSection = sections.find(
  (s: any) => s.data.type === "blog_categories",
);
const recentPostsSection = sections.find((s: any) => s.id === "recent_posts");

// Determine the primary parent section for breadcrumbs
// Priority: Blog Categories > Recent Posts
const parentSection = blogsSection || recentPostsSection;

let categoryCrumb = null;

if (blogsSection && blogsSection.data.categories && post.data.tags) {
  // Find which category this post belongs to based on shared tags
  const matchedCategory = blogsSection.data.categories.find((cat: any) =>
    cat.tags.some((tag: string) => post.data.tags.includes(tag)),
  );

  if (matchedCategory) {
    categoryCrumb = {
      label: matchedCategory.title,
      href: `/blogs/${slugify(matchedCategory.title)}`,
    };
  }
}

// Helper for approximate reading time
const wordCount = post.body ? post.body.split(/\s+/g).length : 0;
const readingTime = Math.ceil(wordCount / 200);

const crumbs: { label: string; href?: string }[] = [
  { label: "Home", href: "/" },
];

if (parentSection) {
  // Use custom_id if available, otherwise default to section id
  const sectionId = (parentSection.data as any).custom_id || parentSection.id;
  crumbs.push({
    label: parentSection.data.title,
    href: `/#${sectionId}`,
  });
}

if (categoryCrumb) {
  crumbs.push(categoryCrumb);
}

crumbs.push({ label: post.data.title });
---

<BaseLayout title={post.data.title} navType="page" tex={true}>
  <Breadcrumbs crumbs={crumbs} showTitle={false} />

  <div class="container">
    <div class="row">
      <section id="blog-post" class="blog-post section col-lg-8">
        <div class="container" data-reveal="fade-up">
          <article class="article">
            {
              post.data.thumbnail && (
                <div class="post-img">
                  <img src={post.data.thumbnail} alt="" class="img-fluid" />
                </div>
              )
            }

            <div class="post-header">
              <h1 class="post-title">{post.data.title}</h1>

              <div class="post-tags">
                {
                  post.data.tags &&
                    post.data.tags.map((tag: string) => (
                      <span class="tag">{tag.toLowerCase()}</span>
                    ))
                }
              </div>

              <div class="meta-top-divider"></div>

              <div class="meta-top">
                <div class="d-flex justify-content-between">
                  <ul id="info" class="d-flex list-unstyled m-0">
                    <li class="d-flex align-items-center me-4">
                      <i class="bi bi-calendar-event me-2"></i>
                      <time
                        >{
                          post.data.date.toLocaleDateString("en-GB", {
                            day: "2-digit",
                            month: "short",
                            year: "numeric",
                          })
                        }</time
                      >
                    </li>
                    <li class="d-flex align-items-center">
                      <i class="bi bi-hourglass-split me-2"></i>
                      <time>{readingTime} min read</time>
                    </li>
                  </ul>

                  <ul id="action" class="d-flex list-unstyled m-0">
                    <li class="d-flex align-items-center">
                      <i class="bi bi-share"></i>
                    </li>
                  </ul>
                </div>
              </div>
              <div class="meta-top-divider"></div>
            </div>

            <div class="post-content">
              <slot />
            </div>
          </article>
        </div>
      </section>

      <BlogSidebar />
    </div>
  </div>
</BaseLayout>
