---
// src/components/sections/Recent_PostsSection.astro
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import ImageAttribution from "../ui/ImageAttribution.astro";
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import Card from "@freelance-persona/components/ui/Card.astro";

interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  tags_to_filter_posts_by?: string[];
  posts?: any[];
  limit?: number;
  columns?: number;
  scale?: number;
}
const {
  id,
  title,
  subtitle,
  tags_to_filter_posts_by,
  posts,
  limit = 3,
  columns = 3,
  scale = 1,
} = Astro.props;

console.log(
  `[FilteredPostsSection] id=${id} tags=${tags_to_filter_posts_by} posts=${posts?.length} limit=${limit} scale=${scale}`,
);

// 1. Fetch ALL posts (only if posts not provided)
const allPosts = posts ? [] : await getCollection("blog_posts");

// 2. Filter Logic
let filteredPosts = posts || [];
if (!posts) {
  filteredPosts = tags_to_filter_posts_by
    ? allPosts.filter((post) =>
        post.data.tags?.some((tag: string) =>
          tags_to_filter_posts_by.includes(tag),
        ),
      )
    : allPosts;
}

// 3. Sort by Date & LIMIT
const displayedPosts = filteredPosts
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, limit === -1 ? undefined : limit);
// 4. Determine Column Class
const colClass =
  columns === 4 ? "col-xl-3 col-lg-4 col-md-6 mb-4" : "col-lg-4 col-md-6 mb-4";

// 5. Excerpt Helper
const getExcerpt = (body: string) => {
  if (!body) return "";
  let text = body
    .replace(/^#+\s+/gm, "") // Remove headers
    .replace(/\[([^\]]+)\]\([^\)]+\)/g, "$1") // Remove links, keep text
    .replace(/[*_`]/g, "") // Remove formatting chars
    .replace(/!\[[^\]]*\]\([^\)]+\)/g, "") // Remove images
    .replace(/<br\s*\/?>/gi, "\n") // Convert <br> to newline
    .trim();

  return text; // Return full text, allow CSS to handle overflow/fade
};
---

{/* Only render the section if we actually found posts for this category */}
{
  displayedPosts.length > 0 && (
    <section
      id={id}
      class="filtered-posts section"
      style={`
        --scale-factor: ${scale};
        /* Downsize key variables by the scale factor */
        --h2-font-size: calc(2rem * var(--scale-factor)); 
        --h3-font-size: calc(1.75rem * var(--scale-factor));
        --normal-font-size: calc(1rem * var(--scale-factor));
        --small-font-size: calc(0.875rem * var(--scale-factor));
        --spacing-sm: calc(1rem * var(--scale-factor));
        --spacing-md: calc(2rem * var(--scale-factor));
      `}
    >
      <SectionTitle title={title} subtitle={subtitle} />

      <div class="container" data-reveal="fade-up">
        <div class="row gy-4" style="--bs-gutter-x: 1.5rem;">
          {displayedPosts.map((post) => (
            <div class={colClass}>
              <Card href={`/posts/${post.id.split("/").pop()}`} class="h-100">
                {/* Image Slot */}
                <div slot="image" class="post-image-container">
                  {post.data.thumbnail ? (
                    <>
                      <Image
                        src={post.data.thumbnail}
                        alt={post.data.title}
                        class="img-fluid post-image"
                        width={600}
                        quality="high"
                        format="webp"
                      />
                      {/* Attribution overlay */}
                      <ImageAttribution
                        img_credit={post.data.img_credit}
                        img_copyright={post.data.img_copyright}
                        img_license={post.data.img_license}
                        disableLinks={true}
                      />
                    </>
                  ) : (
                    <div class="preview-card-wrapper h-100 w-100">
                      <div
                        class="mock-page-content"
                        style="width: 100%; height: 100%; padding: 1rem; background-color: var(--surface-color, #fff); color: var(--default-color); overflow: hidden; position: relative;"
                      >
                        {/* Fade Out Mask Overlay - Applied to container to fade content at bottom */}
                        <div
                          style="
                            position: absolute; 
                            bottom: 0; 
                            left: 0; 
                            width: 100%; 
                            height: 25%; /* FADE START POINT: Adjust height% to control where fade begins (25% = starts lower) */
                            background: linear-gradient(to bottom, transparent, var(--surface-color, #fff)); 
                            z-index: 2;
                            pointer-events: none;
                          "
                        />

                        <div class="post-header">
                          <h2
                            class="post-title"
                            style="font-size: calc(1.25rem * var(--scale-factor)); margin-bottom: 0.25rem; color: var(--heading-color);"
                          >
                            {post.data.title}
                          </h2>

                          <div class="post-tags mb-0">
                            {post.data.tags?.map((tag) => (
                              <span
                                class="tag badge me-1"
                                style="background-color: color-mix(in srgb, var(--default-color), transparent 94%); color: color-mix(in srgb, var(--default-color), transparent 55%); padding: 0.2em 0.6em; border-radius: 0.1rem; font-size: 0.6em;"
                              >
                                {tag.toLowerCase()}
                              </span>
                            )) || <span class="tag badge me-1">blog</span>}
                          </div>

                          <hr style="margin: 0.75rem 0; opacity: 0.2; border-top: 1.5px solid;" />

                          <div
                            class="meta-top d-flex align-items-center mb-2"
                            style="font-size: 0.6rem; color: var(--text-muted);"
                          >
                            <i class="bi bi-calendar-event me-1" />
                            {post.data.date.toLocaleDateString("en-GB", {
                              day: "2-digit",
                              month: "short",
                              year: "numeric",
                            })}
                            <span class="mx-2">|</span>
                            <i class="bi bi-hourglass-split me-1" />1 min read
                          </div>

                          <hr style="margin: 0.5rem 0; opacity: 0.2; border-top: 1.5px solid;" />

                          <div
                            class="post-content"
                            style="font-size: 0.77rem; line-height: 1.2; white-space: pre-line;"
                          >
                            <p>{getExcerpt(post.body)}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                <div class="post-details">
                  <div class="meta mb-4">
                    {/* Tags Display */}
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="d-inline-block">
                        {post.data.tags.map((tag) => {
                          const isFiltered =
                            tags_to_filter_posts_by?.includes(tag);
                          return (
                            <span
                              class="badge me-1"
                              style={`
                                  font-size: calc(0.75em * var(--scale-factor)); 
                                  border-radius: 0.1875rem;
                                  padding: 0.2em 0.6em;
                                  font-weight: 500;
                                  display: inline-flex;
                                  align-items: center;
                                  justify-content: center;
                                  line-height: 1.5;
                                  ${
                                    isFiltered
                                      ? "background-color: color-mix(in srgb, var(--accent-color), transparent 92%); color: color-mix(in srgb, var(--accent-color), transparent 15%);"
                                      : "background-color: color-mix(in srgb, var(--default-color), transparent 94%); color: color-mix(in srgb, var(--default-color), transparent 55%);"
                                  }
                                `}
                            >
                              {tag}
                            </span>
                          );
                        })}
                      </div>
                    )}
                  </div>

                  <div class="post-content" style="flex-grow: 1;">
                    <h3 style="font-weight: 500; font-size: calc(1.25rem * var(--scale-factor)); margin-bottom: 0.5rem;">
                      {post.data.title}
                    </h3>
                    <p style="margin-left: 0; font-size: calc(1rem * var(--scale-factor));">
                      {post.data.description || "Click to read more..."}
                    </p>
                  </div>

                  {/* Date at Bottom Right */}
                  <span
                    class="date"
                    style={`
                        position: absolute;
                        bottom: calc(1rem * var(--scale-factor));
                        right: calc(1.5rem * var(--scale-factor));
                        font-size: calc(0.75em * var(--scale-factor)); 
                        font-weight: 500;
                        line-height: 1.5;
                        color: var(--text-muted);
                      `}
                  >
                    {post.data.date.toLocaleDateString("en-GB", {
                      day: "2-digit",
                      month: "short",
                      year: "numeric",
                    })}
                  </span>
                </div>
              </Card>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  /* Component styles moved to _recent-posts.scss */
  @import "@freelance-persona/styles/_filtered-posts.scss";

  /* Local Fix for Attribution Positioning */
  :global(.post-image-container) {
    position: relative;
    overflow: hidden; /* Ensure attribution stays within image bounds */
  }
</style>
