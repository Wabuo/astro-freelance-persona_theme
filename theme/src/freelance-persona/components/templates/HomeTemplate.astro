---
// src/freelance-persona/components/templates/HomeTemplate.astro

import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@freelance-persona/layouts/BaseLayout.astro";
import { themeConfig } from "@freelance-persona/config";
import Hero from "@freelance-persona/components/Hero.astro";
import PlainSection from "@freelance-persona/components/sections/PlainSection.astro";
import ContactSection from "@freelance-persona/components/sections/ContactSection.astro";
import FilteredPostsSection from "@freelance-persona/components/sections/FilteredPostsSection.astro";
import FeatureSection from "@freelance-persona/components/sections/FeatureSection.astro";
import BlogCategoriesSection from "@freelance-persona/components/sections/BlogCategoriesSection.astro";
import AboutSection from "@freelance-persona/components/sections/AboutSection.astro";
import { getImage } from "astro:assets";

// 1. HERO DATA FETCHING
const heroEntry = await getEntry("sections", "hero");
const heroData = heroEntry?.data || {};

// Optimize/resolve the background image URL for preloading in <head>
const optimizedHeroBg = heroData.background_image
  ? await getImage({
      src: heroData.background_image,
      format: heroData.background_image.format === 'svg' ? 'svg' : 'webp',
      width: 1920,
      height: 1080,
    })
  : null;

// 2. CONTENT SECTIONS
const allSections = await getCollection("sections");
const contentSections = allSections
  .filter((s) => s.id !== "hero")
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={themeConfig.title} navType="home" preloadImageUrl={optimizedHeroBg?.src}>
  <Hero
    title={heroData.title}
    hero_typing_text={heroData.hero_typing_text}
    greeting={heroData.greeting}
    background_image={heroData.background_image}
    background_overlay_transparency={heroData.background_overlay_transparency}
    background_image_anchor={heroData.background_image_anchor}
    img_credit={heroData.img_credit}
    img_copyright={heroData.img_copyright}
    img_license={heroData.img_license}
    img_attribution_position={heroData.img_attribution_position}
    img_attribution_theme={heroData.img_attribution_theme}
    typing_speed={heroData.typing_speed}
    deleting_speed={heroData.deleting_speed}
    pause_duration={heroData.pause_duration}
    position_x={heroData.position_x}
    position_y={heroData.position_y}
    size={heroData.size}
    nudge_x={heroData.nudge_x}
    nudge_y={heroData.nudge_y}
    content_scale={heroData.content_scale}
    title_font_size={heroData.title_font_size}
    typing_font_size={heroData.typing_font_size}
    gap_title_to_typing={heroData.gap_title_to_typing}
    gap_typing_to_socials={heroData.gap_typing_to_socials}
    mobile_position_y={heroData.mobile_position_y}
    mobile_text_align={heroData.mobile_text_align}
    mobile_padding_bottom={heroData.mobile_padding_bottom}
    mobile_image_object_position={heroData.mobile_image_object_position}
  />

  {
    contentSections.map(async (section) => {
      const { Content } = await render(section);

      if (section.data.type === "plain") {
        return (
          <PlainSection
            id={section.id}
            title={section.data.title}
            subtitle={section.data.subtitle}
            nudge_x={section.data.nudge_x}
            nudge_y={section.data.nudge_y}
            content_scale={section.data.content_scale}
            delay={section.data.delay}
          >
            <Content />
          </PlainSection>
        );
      }

      if (section.data.type === "features") {
        return (
          <FeatureSection
            id={section.id}
            title={section.data.title}
            description={section.data.description}
            features={section.data.features}
            nudge_x={section.data.nudge_x}
            nudge_y={section.data.nudge_y}
            content_scale={section.data.content_scale}
            delay={section.data.delay}
          />
        );
      }

      if (section.data.type === "about") {
        return (
          <AboutSection
            id={section.id}
            title={section.data.title}
            subtitle={section.data.subtitle}
            avatar={section.data.avatar}
            avatar_credit={section.data.avatar_credit}
            avatar_copyright={section.data.avatar_copyright}
            avatar_license={section.data.avatar_license}
            qualifications_sidebar={section.data.qualifications_sidebar}
            nudge_x={section.data.nudge_x}
            nudge_y={section.data.nudge_y}
            content_scale={section.data.content_scale}
            delay={section.data.delay}
            avatar_styles={section.data.avatar_styles}
          >
            <Content />
          </AboutSection>
        );
      }

      if (section.data.type === "filtered_posts") {
        return (
          <FilteredPostsSection
            id={section.id}
            title={section.data.title}
            subtitle={section.data.subtitle}
            tags_to_filter_posts_by={section.data.tags_to_filter_posts_by}
            gutter="wide"
          />
        );
      }

      if (section.data.type === "blog_categories") {
        return (
          <BlogCategoriesSection
            id={section.data.custom_id || section.id}
            title={section.data.title}
            subtitle={section.data.subtitle}
            categories={section.data.categories}
            mini_categories={section.data.mini_categories}
            nudge_x={section.data.nudge_x}
            nudge_y={section.data.nudge_y}
            content_scale={section.data.content_scale}
            delay={section.data.delay}
          />
        );
      }

      if (section.data.type === "contact") {
        return <ContactSection entry={section} />;
      }

      return null;
    })
  }
</BaseLayout>
