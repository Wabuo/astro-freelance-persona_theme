---
// src/layouts/BaseLayout.astro
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import { themeConfig } from '../config';

// --- FONTS ---
// Importing here allows Vite to handle the resolution (fixes Sass/PnP errors)
import '@fontsource/poppins/300.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

import '@fontsource/raleway/300.css';
import '@fontsource/raleway/400.css';
import '@fontsource/raleway/500.css';
import '@fontsource/raleway/600.css';
import '@fontsource/raleway/700.css';

import '@fontsource/roboto/300.css';
import '@fontsource/roboto/300-italic.css';
import '@fontsource/roboto/400.css';
import '@fontsource/roboto/400-italic.css';
import '@fontsource/roboto/500.css';
import '@fontsource/roboto/500-italic.css';
import '@fontsource/roboto/700.css';
import '@fontsource/roboto/700-italic.css';

// Import the global asset pipeline (CSS runs fine on server)
import '../styles/main.scss';

interface Props {
  title?: string;
  description?: string;
  tex?: boolean;
  navType?: 'home' | 'page'; 
}

const { 
  title = themeConfig.title, 
  description = themeConfig.description,
  tex = false,
  navType = 'page' 
} = Astro.props;
const bodyClass = navType === 'home' ? 'home-page' : 'inner-page';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={themeConfig.author} />

    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png" />
    
    <meta name="generator" content={Astro.generator} />
  </head>

  <body class={bodyClass} data-tex={tex}>
    <Navigation isHome={navType === 'home'} />

    <i class="nav-toggle d-lg-none bi bi-list"></i>

    <main class="main">
      <slot />
    </main>

    <Footer />

    <div id="preloader"></div>

    <script is:inline>
      // Lightweight preloader script (executes immediately)
      function removePreloader() {
        const preloader = document.getElementById('preloader');
        if (preloader) {
          preloader.style.opacity = '0';
          setTimeout(() => { preloader.remove(); }, 600); // Wait for fade out
        }
      }
      // Remove on load
      window.addEventListener('load', removePreloader);
      // Failsafe: Remove after 1.5s even if page hasn't fully fired 'load'
      setTimeout(removePreloader, 1500);
    </script>

    <script>
      // Island Architecture: Global Scripts
      // We import only what we need for the global layout.
      
      // 1. Scroll Animations (Sal.js)
      import sal from 'sal.js';
      
      document.addEventListener('DOMContentLoaded', () => {
        sal({
          threshold: 0.1,
          once: true,
        });
      });

      // 2. Dynamic KaTeX Loading (Local & Privacy-friendly)
      const body = document.querySelector('body');
      if (body && body.dataset.tex === 'true') {
        // Dynamically import KaTeX only when needed
        Promise.all([
          import('katex/dist/katex.min.css'),
          import('katex/dist/contrib/auto-render.js')
        ]).then(([_, autoRenderModule]) => {
          // The auto-render module exports default function
          const renderMathInElement = autoRenderModule.default || autoRenderModule;
          
          renderMathInElement(document.body, {
            delimiters: [
              {left: '$$', right: '$$', display: true},
              {left: '$', right: '$', display: false},
              {left: '\\(', right: '\\)', display: false},
              {left: '\\[', right: '\\]', display: true}
            ],
            throwOnError : false
          });
        }).catch(err => console.error("Failed to load KaTeX:", err));
      }
    </script>
  </body>
</html>