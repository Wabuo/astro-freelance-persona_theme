{
  "name": "astro-persona-theme",
  "version": "0.1.0",
  "description": "A modern, responsive and lightweight theme for resume, portfolio, and blog. Ported from Zola to Astro.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./components/*": "./src/components/*",
    "./layouts/*": "./src/layouts/*",
    "./styles/*": "./src/styles/*"
  },
  "bin": "./bin/init.mjs",
  "files": [
    "src",
    "bin",
    "public",
    "starter",
    "astro.config.mjs",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "astro",
    "theme",
    "portfolio",
    "resume"
  ],
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/raleway": "^5.2.8",
    "@fontsource/roboto": "^5.2.9",
    "academicons": "^1.9.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "fontsource": "^0.0.1-security",
    "glightbox": "^3.3.1",
    "imagesloaded": "^5.0.0",
    "isotope-layout": "^3.0.6",
    "katex": "^0.16.27",
    "swiper": "^12.0.3",
    "typed.js": "^2.1.0"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^25.0.2",
    "astro": "^5.16.5",
    "sass": "^1.96.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview"
  }
}
