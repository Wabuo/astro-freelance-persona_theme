---
// src/freelance-persona/components/Footer.astro
import { themeConfig } from "@freelance-persona/config";
import { parse } from "marked"; // <--- The "real" parser

const { title, quote, social_links, copyright, credits } = themeConfig;

// Logic to append dynamic credits (e.g., Form Provider)
let providerCredit = "";

if (themeConfig.contact_form?.provider === "formspark") {
  providerCredit = ", contact form via [Formspark](https://formspark.io)";
} else if (themeConfig.contact_form?.provider === "web3forms") {
  providerCredit = ", contact form via [Web3Forms](https://web3forms.com)";
} else if (themeConfig.contact_form?.provider === "ntfy") {
  const ntfyServer = themeConfig.contact_form?.ntfy_server || "https://ntfy.sh";
  providerCredit = `, contact form via [ntfy](https://github.com/binwiederhier/ntfy) hosted at [${ntfyServer}](${ntfyServer})`;
} else if (themeConfig.contact_form?.provider === "netlify") {
  providerCredit =
    ", contact form via [Netlify Forms](https://www.netlify.com/products/forms/)";
}

// Normalize credits to array for manipulation
let creditsArray = Array.isArray(credits) ? [...credits] : [credits || ""];

// Append provider credit to the FIRST line (Powered By...)
if (providerCredit && creditsArray.length > 0) {
  creditsArray[0] += providerCredit;
}

// Join lines with explicit break and parse
const finalCreditsString = creditsArray.join(" <br> ");
const creditsHtml = await parse(finalCreditsString);
---

<footer id="footer" class="footer position-relative">
  <div class="container">
    <h3 class="sitename">{title}</h3>
    <p class="quote">{quote}</p>

    <div class="social-links d-flex justify-content-center">
      {
        social_links.map((link: any) => (
          <a
            href={link.url}
            aria-label={`Link to my ${link.name} profile`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class={link.icon_class} aria-hidden="true" />
          </a>
        ))
      }
    </div>

    <div class="container">
      <div class="copyright">
        <span set:html={copyright} />
        {
          themeConfig.legal?.enabled && (
            <>
              <span class="legal-separator mx-2">|</span>
              <a href="/legal/legal-notice" class="legal-link">
                {themeConfig.legal.link_text || "Legal Notice"}
              </a>
            </>
          )
        }
      </div>
      {/* Render the fully parsed HTML */}
      <div class="credits" set:html={creditsHtml} />
    </div>
  </div>
</footer>
