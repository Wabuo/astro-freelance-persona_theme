---
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import LanceIcon from "@freelance-persona/components/ui/LanceIcon.astro";
import Card from "@freelance-persona/components/ui/Card.astro";
import { themeConfig } from "@freelance-persona/config";
import { slugify } from "@freelance-persona/utils/slugify";
import { resolveLink } from "@freelance-persona/utils/linkUtils";
import { Icon } from "astro-icon/components";
import { transformIcon } from "@freelance-persona/utils/iconUtils";
import { replaceBuildTokens } from "@freelance-persona/utils/buildInfo";

interface Props {
  id: string;
  title: string;
  description?: string;
  features: {
    title: string;
    desc: string;
    icon?: string;
    secondary_icon?: string;
    link?: string;
    unavailable?: boolean;
    button_text?: string;
    unavailable_button_text: string;
  }[];
  nudge_x?: string;
  nudge_y?: string;
  content_scale?: number;
  delay?: number;
}

const {
  id,
  title,
  description,
  features,
  nudge_x,
  nudge_y,
  content_scale,
  delay,
} = Astro.props;

// Visual Overrides CSS
const sectionStyle = `
  ${nudge_x ? `--nudge-x: ${nudge_x};` : ""}
  ${nudge_y ? `--nudge-y: ${nudge_y};` : ""}
  ${content_scale ? `--content-scale: ${content_scale};` : ""}
`;

const defaultContentDelay = themeConfig.visuals?.delays?.content || 200;
const staggerDelay = themeConfig.visuals?.delays?.stagger || 100;
---

<section id={id} class="features-section-wrapper section" style={sectionStyle}>
  <div class="features-background"></div>
  <div class="container features-container">
    <SectionTitle title={title} subtitle={description} />

    <div class="features-grid">
      {
        features.map((feature, index) => {
          // const slugify = ... (Moved to utils)

          const isUnavailable = feature.unavailable === true;

          const rawLink = isUnavailable
            ? undefined
            : feature.link
            ? feature.link
            : `services/${slugify(feature.title)}`;

          const finalLink = resolveLink(rawLink);

          return (
            <div
              class="feature-group-wrapper"
              data-reveal="fade-up"
              data-reveal-delay={
                delay || defaultContentDelay + index * staggerDelay
              }
            >
              <Card
                href={finalLink}
                class={`feature-card h-100 ${
                  isUnavailable ? "unavailable" : ""
                }`}
              >
                {/* Card Content - Icon Logic */}
                {feature.icon && (
                  <div class="feature-icon-wrapper-outer">
                    <div
                      class={`feature-icon-bg ${
                        feature.secondary_icon ? "has-secondary-icon" : ""
                      }`}
                    >
                      {/* Main Icon */}
                      {feature.icon === "lance-icon" ? (
                        <LanceIcon class="feature-icon lance-icon-svg icon-main" />
                      ) : (
                        <Icon name={transformIcon(feature.icon)} class="feature-icon icon-main" />
                      )}

                      {/* Secondary Icon */}
                      {feature.secondary_icon && (
                        <Icon
                          name={transformIcon(feature.secondary_icon)}
                          class="feature-icon icon-secondary"
                        />
                      )}
                    </div>
                  </div>
                )}
                {finalLink && <div class="feature-card-shadow" />}

                <h3 class="feature-title-card">{feature.title}</h3>
                <p class="feature-description-card">{replaceBuildTokens(feature.desc)}</p>

                {(feature.button_text || isUnavailable) && (
                  <div class="feature-hover-action">
                    {isUnavailable
                      ? feature.unavailable_button_text
                      : feature.button_text}
                  </div>
                )}
              </Card>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .features-section-wrapper {
    transform: translate(var(--nudge-x, 0), var(--nudge-y, 0))
      scale(var(--content-scale, 1));
  }

  /* Icon Logic */
  .feature-icon-bg {
    position: relative; /* Context for absolute icon */
    display: inline-flex; /* Ensure centering */
    justify-content: center;
    align-items: center;
  }

  .feature-icon {
    /* Sized via font-size: 1.5rem in features.scss — no box-model overrides needed for <i> elements */
  }

  /* Default state for Secondary Icon is hidden (unless parent has-secondary-icon) */
  .feature-icon.icon-secondary {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
  }

  /* 
    Permanent Dual Icon Layout (Flexbox)
    - Automatically centers the pair.
    - Gap controls spacing.
  */
  .feature-icon-bg.has-secondary-icon {
    gap: 0.25rem; /* Adjust this to change spacing transparently */
  }

  .feature-icon-bg.has-secondary-icon .icon-main {
    transform: none; /* No manual shifting needed */
  }

  .feature-icon-bg.has-secondary-icon .icon-secondary {
    position: static; /* Join the flex flow */
    transform: none;
    opacity: 1;
  }

  /* Removed Hover Triggers - No animation */
</style>
