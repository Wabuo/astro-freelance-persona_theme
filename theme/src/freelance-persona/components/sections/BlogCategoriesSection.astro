---
import SectionTitle from "@freelance-persona/components/ui/SectionTitle.astro";
import Card from "@freelance-persona/components/ui/Card.astro";
import { themeConfig } from "@freelance-persona/config";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { slugify } from "@freelance-persona/utils/slugify";
import ImageAttribution from "@freelance-persona/components/ui/ImageAttribution.astro";

import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  title: string;
  subtitle?: string;
  categories: {
    title: string;
    image?: ImageMetadata;
    img_credit?: { name: string; url?: string; icon?: string } | "hidden";
    img_copyright?: string;
    img_license?: string | { license: string; url: string } | "hidden";
    background_color?: string;
    tags: string[];
    description?: string;
    overlay_title?: boolean;
    overlay_style?: "dark" | "light" | "accent" | "custom" | "none";
    custom_overlay_color?: string;
    mix_accent?: number;
    overlay_opacity?: number;
    title_style?: "dark" | "light" | "custom";
    custom_title_color?: string;
  }[];
  mini_categories?: {
    title: string;
    description?: string;
    tags: string[];
    background_color?: string;
    color?: string;
  }[];
  nudge_x?: string;
  nudge_y?: string;
  content_scale?: number;
  delay?: number;
}

const {
  id,
  title,
  subtitle,
  categories,
  mini_categories,
  nudge_x,
  nudge_y,
  content_scale,
  delay,
} = Astro.props;

// Fetch all blog posts once
const allPosts = await getCollection("blog_posts");
const sortedPosts = allPosts.sort((a, b) => {
  const dateDiff = b.data.date.valueOf() - a.data.date.valueOf();
  if (dateDiff !== 0) return dateDiff;
  return b.id.localeCompare(a.id);
});

// Visual Overrides CSS
const sectionStyle = `
  ${nudge_x ? `--nudge-x: ${nudge_x};` : ""}
  ${nudge_y ? `--nudge-y: ${nudge_y};` : ""}
  ${content_scale ? `--content-scale: ${content_scale};` : ""}
`;

const defaultContentDelay = themeConfig.visuals?.delays?.content || 200;
const staggerDelay = themeConfig.visuals?.delays?.stagger || 100;
// Helper to resolve images (assuming public folder for now if string)
// If you want robust image optimization, we might need a dynamic import map or glob
// For now, we'll try to use standard img tag or Image if it's a URL
---

<section id={id} class="blog-categories-section section" style={sectionStyle}>
  <div class="container">
    <SectionTitle title={title} subtitle={subtitle} />

    <div class="blog-categories-grid">
      {
        categories.map((category, index) => {
          // Filter posts for this category
          const categoryPosts = sortedPosts
            .filter((post) =>
              post.data.tags.some((tag: string) => category.tags.includes(tag))
            )
            .slice(0, 2);

          // Basic link construction - Link to the dedicated category page
          const linkUrl = `/blogs/${slugify(category.title)}`;

          // Resolve Overlay Colors
          const opacity = category.overlay_opacity ?? 0.4;
          const mixAccent = category.mix_accent; // Undefined or number

          let baseColor = "transparent";

          // 1. Resolve Base Color
          if (category.overlay_title) {
            if (category.overlay_style === "dark") {
              baseColor = "var(--default-color)";
            } else if (category.overlay_style === "light") {
              baseColor = "var(--contrast-color)";
            } else if (category.overlay_style === "custom") {
              baseColor = category.custom_overlay_color || "transparent";
            } else if (category.overlay_style === "none") {
              baseColor = "transparent";
            }
          }

          // 2. Apply Accent Mix (Tint)
          // If mixAccent is defined (number), we mix it in at that percentage
          if (mixAccent !== undefined && mixAccent !== null) {
            // Mix accent into the base (mixAccent% accent, Remainder base)
            baseColor = `color-mix(in srgb, var(--accent-color) ${mixAccent}%, ${baseColor})`;
          }

          // 3. Apply Transparency
          // Mix the resulting Base Tint with transparent
          let overlayBg = `color-mix(in srgb, ${baseColor}, transparent ${
            (1 - opacity) * 100
          }%)`;

          if (category.overlay_style === "none") {
            overlayBg = "transparent";
          }

          // Resolve Title Color
          let titleColor = "var(--heading-color)"; // Default to standard heading color

          // Resolve "Static/Contextual" Colors from Config
          // User Request: 'dark' style should use the default color from the LIGHT theme (Dark Text)
          //               'light' style should use the default color from the DARK theme (Light Text)
          const staticLightHeading =
            themeConfig.colors?.light?.heading || "#45505b"; // Dark Grey
          const staticDarkHeading =
            themeConfig.colors?.dark?.heading || "#ffffff"; // White

          if (category.title_style === "light") {
            titleColor = staticDarkHeading;
          } else if (category.title_style === "dark") {
            titleColor = staticLightHeading;
          } else if (category.title_style === "custom") {
            titleColor = category.custom_title_color || "inherit";
          } else if (category.overlay_title) {
            // Fallback logic specific to Overlay mode if no explicit style matches
            if (category.overlay_style === "light")
              titleColor = "var(--default-color)";
            else titleColor = "var(--contrast-color)";
          }

          const cardStyle = `
            --overlay-bg: ${overlayBg};
            --overlay-title-color: ${titleColor};
          `;

          return (
            <div
              class="category-card-wrapper"
              data-reveal="fade-up"
              data-reveal-delay={
                delay || defaultContentDelay + index * staggerDelay
              }
              style={cardStyle}
            >
              <Card class="category-card h-100">
                <a
                  href={linkUrl}
                  class="card-link-overlay"
                  aria-label={category.title}
                />
                <div slot="image" class="category-image-container">
                  {category.image ? (
                    <Image
                      src={category.image}
                      alt={category.title}
                      class="category-image"
                      width={600}
                    />
                  ) : (
                    <div
                      class="category-image"
                      style={`background-color: ${
                        category.background_color || "var(--surface-color)"
                      }; width: 100%; height: 100%;`}
                    />
                  )}
                  {category.overlay_title && (
                    <div class="overlay-title-wrapper">
                      <h3 class="overlay-title-text">{category.title}</h3>
                    </div>
                  )}
                  {/* Reuse ImageAttribution Component */}
                  <ImageAttribution
                    img_credit={category.img_credit}
                    img_copyright={category.img_copyright}
                    img_license={category.img_license}
                  />
                </div>

                {!category.overlay_title && (
                  <h3
                    class="category-title"
                    style={
                      category.title_style
                        ? `color: ${titleColor} !important;`
                        : ""
                    }
                  >
                    {category.title}
                  </h3>
                )}

                {category.description && (
                  <p
                    class={`category-description ${
                      category.overlay_title ? "prominent" : ""
                    }`}
                  >
                    {category.description}
                  </p>
                )}

                <div class="category-tags">
                  {category.tags.map((tag) => (
                    <span class="badge active">{tag}</span>
                  ))}
                </div>

                <div class="latest-posts">
                  <div class="latest-posts-separator" />
                  {categoryPosts.length > 0 ? (
                    <ul class="latest-posts-list">
                      {categoryPosts.map((post) => (
                        <li class="recent-post-item">
                          <a
                            href={`/posts/${post.id.split("/").pop()}`}
                            class="recent-post-link"
                          >
                            <span class="post-title">{post.data.title}</span>
                            <span class="post-date">
                              {post.data.date.toLocaleDateString("en-GB", {
                                day: "2-digit",
                                month: "short",
                                year: "numeric",
                              })}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p
                      class="no-posts-message"
                      style="font-size: 0.8rem; color: color-mix(in srgb, var(--default-color), transparent 40%); font-style: italic;"
                    >
                      No posts yet
                    </p>
                  )}
                </div>
              </Card>
            </div>
          );
        })
      }
    </div>

    {/* Mini Categories Grid - Separate container for layout control */}
    {
      mini_categories && mini_categories.length > 0 && (
        <div
          class="blog-categories-grid mini-categories-grid"
          style="margin-top: var(--mini-group-gap, 2rem);"
        >
          {mini_categories?.map((category, index) => {
            const miniCardStyle = category.background_color
              ? `background-color: ${category.background_color};`
              : "";
            const textColorStyle = category.color
              ? `color: ${category.color};`
              : "";
            const combinedStyle = [miniCardStyle, textColorStyle]
              .filter(Boolean)
              .join(" ");

            const linkUrl = `/blogs/${slugify(category.title)}`;

            return (
              <div
                class="mini-category-card-wrapper"
                data-reveal="fade-up"
                data-reveal-delay={
                  delay ||
                  defaultContentDelay +
                    (categories.length + index) * staggerDelay
                }
              >
                <Card class="mini-category-card h-100" style={combinedStyle}>
                  <a
                    href={linkUrl}
                    class="card-link-overlay"
                    aria-label={category.title}
                  />
                  <h3
                    class="category-title"
                    style={
                      category.color
                        ? `color: ${category.color} !important; margin-top: 0;`
                        : "margin-top: 0;"
                    }
                  >
                    {category.title}
                  </h3>
                  {category.description && (
                    <p
                      class="category-description"
                      style={category.color ? `color: ${category.color};` : ""}
                    >
                      {category.description}
                    </p>
                  )}
                  <div class="category-tags">
                    {category.tags.map((tag) => (
                      <span
                        class="badge active"
                        style={
                          category.color
                            ? `background: color-mix(in srgb, black, transparent 90%); color: ${category.color};`
                            : ""
                        }
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </Card>
              </div>
            );
          })}
        </div>
      )
    }
  </div>
</section>
